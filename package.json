{
  "name": "identidad-artificial",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build:data": "node scripts/generate-knowledge-map.mjs && node scripts/generate-post-insights.mjs && node scripts/generate-editorial-radar.mjs",
    "build": "npm run build:data && node scripts/generate-og.mjs && astro build",
    "test": "node --import tsx --test tests/*.test.mjs tests/*.test.ts",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy --config dist/server/wrangler.json",
    "memory:ingest": "node --import tsx scripts/editorial-memory/ingest.ts",
    "memory:preview": "node --import tsx scripts/editorial-memory/preview.ts",
    "memory:doctor": "node --import tsx scripts/editorial-memory/doctor.ts",
    "memory:reset": "node --import tsx scripts/editorial-memory/reset.ts",
    "memory:check": "node --import tsx scripts/editorial-memory/check.ts",
    "memory:search": "node --import tsx scripts/editorial-memory/search.ts",
    "gsc:oauth": "node scripts/google-search-console-oauth.mjs",
    "gsc:report": "node scripts/download-search-console-report.mjs",
    "gsc:inspect": "node scripts/inspect-search-console-urls.mjs",
    "gsc:submit-sitemap": "node scripts/submit-search-console-sitemap.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@qdrant/js-client-rest": "^1.18.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.3",
    "astro": "^6.1.8",
    "gray-matter": "^4.0.3",
    "openai": "^6.38.0",
    "satori": "^0.26.0",
    "tailwindcss": "^4.2.3",
    "typescript": "^5.9.3",
    "wawoff2": "^2.0.1",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "tsx": "^4.22.2",
    "wrangler": "^4.84.1"
  },
  "overrides": {
    "vite": "^7",
    "yaml": "$yaml"
  }
}
