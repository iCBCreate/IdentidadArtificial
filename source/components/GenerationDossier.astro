---
interface Props {
  generatedBy: string
  generatedAt: Date
  promptBase: string
  humanReviewed: boolean
  correctionNote?: string
  reviewNotes?: string
  sourceQuality?: 'Alta' | 'Media' | 'Baja'
  confidenceLevel?: 'Alta' | 'Media' | 'Baja'
  claimsReviewed?: string[]
}

const {
  generatedBy,
  generatedAt,
  promptBase,
  humanReviewed,
  correctionNote,
  reviewNotes,
  sourceQuality = humanReviewed ? 'Media' : 'Baja',
  confidenceLevel = humanReviewed ? 'Media' : 'Baja',
  claimsReviewed = [],
} = Astro.props

const formattedDate = generatedAt.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const checklist = [
  { label: 'Frontmatter validado por Zod', ok: true },
  { label: 'Lecturas derivadas generadas en build-time', ok: true },
  { label: 'Revisión humana declarada', ok: humanReviewed },
  { label: 'Claims críticos documentados', ok: claimsReviewed.length > 0 },
]
---

{correctionNote && (
  <div class="mt-12 border border-amber-500/40 rounded-lg p-4 bg-amber-500/5 flex gap-3">
    <span class="text-amber-400 text-lg shrink-0">!</span>
    <div>
      <p class="text-xs font-semibold text-amber-400 uppercase tracking-widest mb-1">Corrección</p>
      <p class="text-sm text-[#C8C8E0]">{correctionNote}</p>
    </div>
  </div>
)}

<aside class="mt-4 dossier">
  <div class="dossier-head">
    <div>
      <p class="eyebrow">Expediente IA</p>
      <h3>Cómo se generó este artículo</h3>
    </div>
    <span class={`badge badge-${confidenceLevel.toLowerCase()}`}>Confianza {confidenceLevel}</span>
  </div>

  <div class="dossier-grid">
    <div>
      <span>Modelo</span>
      <strong>{generatedBy}</strong>
    </div>
    <div>
      <span>Generado</span>
      <strong>{formattedDate}</strong>
    </div>
    <div>
      <span>Fuentes</span>
      <strong>{sourceQuality}</strong>
    </div>
    <div>
      <span>Revisión</span>
      <strong>{humanReviewed ? 'Humana' : 'Pendiente'}</strong>
    </div>
  </div>

  <div class="prompt-box">
    <span>Prompt base</span>
    <p>{promptBase}</p>
  </div>

  {reviewNotes && (
    <div class="notes-box">
      <span>Notas de revisión</span>
      <p>{reviewNotes}</p>
    </div>
  )}

  <div class="checklist">
    {checklist.map(item => (
      <div class={item.ok ? 'check ok' : 'check pending'}>
        <span>{item.ok ? '✓' : '·'}</span>
        <p>{item.label}</p>
      </div>
    ))}
  </div>

  {claimsReviewed.length > 0 && (
    <div class="claims">
      <span>Claims revisados</span>
      <ul>
        {claimsReviewed.map(claim => <li>{claim}</li>)}
      </ul>
    </div>
  )}
</aside>

<style>
.dossier {
  border: 1px solid rgba(109, 40, 217, 0.32);
  border-radius: 8px;
  padding: 24px;
  background: linear-gradient(180deg, rgba(109, 40, 217, 0.08), rgba(19, 19, 31, 0.7));
}
.dossier-head {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
  margin-bottom: 20px;
}
.eyebrow, .dossier-grid span, .prompt-box span, .notes-box span, .claims span {
  display: block;
  color: #A78BFA;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
}
.dossier h3 {
  color: #E8E8F0;
  font-size: 20px;
  font-weight: 800;
  margin-top: 4px;
}
.badge {
  border: 1px solid #2A2A40;
  border-radius: 999px;
  color: #E8E8F0;
  font-size: 12px;
  padding: 6px 10px;
  white-space: nowrap;
}
.badge-alta { border-color: rgba(52, 211, 153, .5); color: #86EFAC; }
.badge-media { border-color: rgba(251, 191, 36, .5); color: #FDE68A; }
.badge-baja { border-color: rgba(248, 113, 113, .5); color: #FCA5A5; }
.dossier-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  background: #2A2A40;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 16px;
}
.dossier-grid div {
  background: #171726;
  padding: 14px;
  min-width: 0;
}
.dossier-grid strong {
  display: block;
  color: #E8E8F0;
  font-size: 13px;
  margin-top: 6px;
  overflow-wrap: anywhere;
}
.prompt-box, .notes-box, .claims {
  border-top: 1px solid #2A2A40;
  padding-top: 16px;
  margin-top: 16px;
}
.prompt-box p, .notes-box p, .claims li {
  color: #C8C8E0;
  font-size: 14px;
  line-height: 1.7;
}
.prompt-box p { font-style: italic; margin-top: 8px; }
.checklist {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 16px;
}
.check {
  display: flex;
  gap: 8px;
  align-items: center;
  color: #C8C8E0;
  font-size: 13px;
}
.check span { color: #34D399; font-weight: 800; }
.check.pending span { color: #FBBF24; }
.claims ul {
  margin-top: 10px;
  padding-left: 18px;
}
@media (max-width: 700px) {
  .dossier-grid, .checklist { grid-template-columns: 1fr; }
  .dossier-head { flex-direction: column; }
}
</style>
