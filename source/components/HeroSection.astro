---
const pills = [
  ['Claude Managed Agents', 'Modelos', 'agentes', 'automatización', 'productividad', 'Claude', 'Anthropic'],
  ['contexto en LLM', 'conceptos', 'tokens', 'ventana de contexto', 'llm', 'modelos de lenguaje'],
  ['Astro', 'arquitectura', 'jamstack', 'desarrollo web', 'blog generado por IA', 'static site'],
  ['agentes de IA', 'inteligencia artificial', 'herramientas', 'revisión humana', 'transparencia'],
  ['Claude Code', 'generative ai', 'cómo funciona', 'fine-tuning', 'rag', 'embeddings', 'reasoning'],
]
---

<section class="hero-section">
  <!-- Pills de fondo -->
  <div class="pills-bg" aria-hidden="true">
    {pills.map((row, i) => (
      <div class={`pill-row pill-row-${i % 2 === 0 ? 'left' : 'right'}`}>
        {[...row, ...row, ...row].map(pill => (
          <span class="pill">{pill}</span>
        ))}
      </div>
    ))}
  </div>

  <!-- Gradiente central -->
  <div class="pills-overlay"></div>

  <!-- Contenido -->
  <div class="hero-content">
    <h1 class="hero-title">
      <span class="word accent-word">Identidad</span>{' '}
      <span class="word">Artificial</span>{' '}
      <span class="word dim-word">—</span>{' '}
      <span class="word">IA desde dentro</span>
    </h1>
    <p class="hero-subtitle">
      <span class="hero-hl">Artículos técnicos</span> sobre inteligencia artificial —<br />
      generados por Claude, revisados por humanos.
    </p>
    <div class="hero-cta">
      <a href="#entradas" class="btn-primary">Últimas entradas</a>
      <a href="/como-funciona/" class="btn-secondary">Cómo funciona →</a>
    </div>
  </div>
</section>

<style>
.hero-section {
  position: relative;
  overflow: hidden;
  min-height: 320px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* --- Pills background --- */
.pills-bg {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 20px 0;
  pointer-events: none;
  user-select: none;
}

.pill-row {
  display: flex;
  gap: 10px;
  white-space: nowrap;
  width: max-content;
}

.pill-row-left  { animation: scrollLeft  22s linear infinite; }
.pill-row-right { animation: scrollRight 28s linear infinite; }

.pill-row:nth-child(3) { animation-duration: 18s; }
.pill-row:nth-child(5) { animation-duration: 32s; }

@keyframes scrollLeft  { from { transform: translateX(0);          } to { transform: translateX(-33.333%); } }
@keyframes scrollRight { from { transform: translateX(-33.333%);   } to { transform: translateX(0);        } }

.pill {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: 20px;
  border: 1px solid rgba(167, 139, 250, 0.18);
  background: rgba(109, 40, 217, 0.07);
  color: rgba(160, 160, 192, 0.5);
  font-size: 11px;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

/* Gradiente que hace legible el título */
.pills-overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 60% 70% at 50% 50%,
    rgba(19, 19, 31, 0.94) 0%,
    rgba(19, 19, 31, 0.60) 55%,
    transparent 100%
  );
  pointer-events: none;
}

/* --- Hero content --- */
.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 600px;
  padding: 48px 24px;
}

.hero-title {
  font-size: clamp(28px, 5vw, 42px);
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -1.5px;
  color: #E8E8F0;
  margin-bottom: 16px;
}

.word {
  display: inline-block;
  opacity: 0;
  transform: translateY(10px);
  animation: fadeUp 0.4s forwards;
}
.word:nth-child(1) { animation-delay: 0.1s; }
.word:nth-child(2) { animation-delay: 0.2s; }
.word:nth-child(3) { animation-delay: 0.3s; }
.word:nth-child(4) { animation-delay: 0.4s; }

.accent-word { color: #A78BFA; }
.dim-word    { color: #4A4A6A; }

.hero-subtitle {
  font-size: 15px;
  color: #A0A0C0;
  line-height: 1.65;
  margin-bottom: 28px;
  opacity: 0;
  animation: fadeUp 0.5s 0.6s forwards;
}
.hero-hl { color: #C4B5FD; }

.hero-cta {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.5s 0.8s forwards;
}

.btn-primary {
  background: #6D28D9;
  color: #fff;
  font-size: 13px;
  font-weight: 600;
  padding: 10px 22px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.15s;
}
.btn-primary:hover { background: #7C3AED; }

.btn-secondary {
  background: transparent;
  border: 1px solid #2E2E48;
  color: #A0A0C0;
  font-size: 13px;
  padding: 10px 22px;
  border-radius: 6px;
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s;
}
.btn-secondary:hover { border-color: #6D28D9; color: #E8E8F0; }

@keyframes fadeUp {
  to { opacity: 1; transform: translateY(0); }
}
</style>
