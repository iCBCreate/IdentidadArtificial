---
---
<div class="nt-bar" role="marquee" aria-label="Titulares de inteligencia artificial en tiempo real" aria-live="off">
  <span class="nt-label">IA AHORA</span>
  <div class="nt-track-wrap" id="nt-wrap" tabindex="0">
    <div class="nt-track" id="nt-track">
      <!-- Filled by client JS; static fallback below if JS disabled -->
      <noscript>
        <span class="nt-item">Últimas noticias de inteligencia artificial</span>
        <span class="nt-sep">◆</span>
        <span class="nt-item">Modelos de lenguaje, agentes y más</span>
        <span class="nt-sep">◆</span>
        <span class="nt-item">Identidad Artificial — el pulso de la IA</span>
      </noscript>
    </div>
  </div>
</div>

<style>
.nt-bar {
  display: flex;
  align-items: center;
  background: #13131F;
  border-top: 1px solid #7C3AED;
  border-bottom: 1px solid #2A2A40;
  height: 34px;
  overflow: hidden;
}

.nt-label {
  background: #7C3AED;
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0 12px;
  height: 100%;
  display: flex;
  align-items: center;
  white-space: nowrap;
  flex-shrink: 0;
}

.nt-track-wrap {
  flex: 1;
  overflow-x: auto;
  overflow-y: hidden;
  height: 100%;
  position: relative;
  touch-action: pan-x;
  overscroll-behavior-x: contain;
  cursor: grab;
  scrollbar-width: none;
}

.nt-track-wrap::-webkit-scrollbar {
  display: none;
}

.nt-track-wrap.dragging {
  cursor: grabbing;
}

.nt-track {
  display: flex;
  align-items: center;
  height: 100%;
  white-space: nowrap;
}

@media (prefers-reduced-motion: reduce) {
  /* auto-advance is suppressed in JS via matchMedia; drag still works */
}

/* :global() needed — these elements are created dynamically via JS and don't receive the Astro scoped attribute */
:global(.nt-item) {
  color: #C4B5FD;
  font-size: 11px;
  padding: 0 8px;
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  transition: color 0.15s;
}

:global(a.nt-item:hover) {
  color: #E8E8F0;
}

:global(.nt-sep) {
  color: #4A4A6A;
  font-size: 9px;
  padding: 0 14px;
  flex-shrink: 0;
}

:global(.nt-loading) {
  color: #4A4A6A;
  font-size: 10px;
  padding: 0 14px;
  font-style: italic;
}
</style>

<script>
(function () {
  const track = document.getElementById('nt-track')
  if (!track) return

  const FALLBACK = [
    { title: 'Últimas noticias de inteligencia artificial en español', link: '' },
    { title: 'Modelos de lenguaje: avances y tendencias del sector', link: '' },
    { title: 'Agentes autónomos, RAG y el futuro de la IA generativa', link: '' },
  ]

  function buildItems(articles: { title: string; link: string }[]) {
    return articles.map(a => {
      if (a.link) {
        const el = document.createElement('a')
        el.className = 'nt-item'
        el.href = a.link
        el.target = '_blank'
        el.rel = 'noopener noreferrer'
        el.textContent = a.title
        return el
      }
      const el = document.createElement('span')
      el.className = 'nt-item'
      el.textContent = a.title
      return el
    })
  }

  function renderTicker(el: HTMLElement, articles: { title: string; link: string }[]) {
    while (el.firstChild) el.removeChild(el.firstChild)

    const sep = () => {
      const s = document.createElement('span')
      s.className = 'nt-sep'
      s.textContent = '◆'
      return s
    }

    // One copy = every item followed by a separator (fresh DOM nodes per call)
    const makeCopy = () => {
      const frag = document.createDocumentFragment()
      buildItems(articles).forEach(item => {
        frag.appendChild(item)
        frag.appendChild(sep())
      })
      return frag
    }

    const wrap = document.getElementById('nt-wrap') as HTMLElement | null
    if (!wrap) return

    // First copy, then keep adding copies until there is at least one full
    // viewport of content beyond a single copy. This guarantees the wrap point
    // (one copy width) is reachable by scrollLeft, so the loop stays seamless
    // for any number of headlines (short fallback list included).
    el.appendChild(makeCopy())
    const copyWidth = el.scrollWidth
    let copies = 1
    while (el.scrollWidth - copyWidth < wrap.clientWidth && copies < 20) {
      el.appendChild(makeCopy())
      copies++
    }
    if (copies < 2) el.appendChild(makeCopy())

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    let paused = false
    let dragging = false
    let moved = 0
    let startX = 0
    let startScroll = 0
    let resumeTimer: ReturnType<typeof setTimeout> | undefined
    let lastT = 0

    function normalize() {
      if (copyWidth <= 0) return
      if (wrap.scrollLeft >= copyWidth) wrap.scrollLeft -= copyWidth
      else if (wrap.scrollLeft < 0) wrap.scrollLeft += copyWidth
    }

    function scheduleResume() {
      clearTimeout(resumeTimer)
      resumeTimer = setTimeout(() => { paused = false }, 2500)
    }

    function frame(t: number) {
      if (lastT !== 0) {
        const dt = (t - lastT) / 1000
        if (!reduced && !paused && !dragging && wrap.scrollWidth > wrap.clientWidth) {
          wrap.scrollLeft += 60 * dt
          normalize()
        }
      }
      lastT = t
      requestAnimationFrame(frame)
    }

    // Mouse drag via Pointer Events. Touch uses native scroll (momentum).
    wrap.addEventListener('pointerenter', () => { paused = true })
    wrap.addEventListener('pointerleave', scheduleResume)
    wrap.addEventListener('focus', () => { paused = true })
    wrap.addEventListener('blur', scheduleResume)

    wrap.addEventListener('pointerdown', (e: PointerEvent) => {
      if (e.pointerType !== 'mouse') return
      dragging = true
      moved = 0
      startX = e.clientX
      startScroll = wrap.scrollLeft
      wrap.setPointerCapture(e.pointerId)
      wrap.classList.add('dragging')
      paused = true
    })

    wrap.addEventListener('pointermove', (e: PointerEvent) => {
      if (!dragging) return
      const dx = e.clientX - startX
      moved = Math.max(moved, Math.abs(dx))
      wrap.scrollLeft = startScroll - dx
      normalize()
    })

    const endDrag = () => {
      if (!dragging) return
      dragging = false
      wrap.classList.remove('dragging')
      scheduleResume()
    }
    wrap.addEventListener('pointerup', endDrag)
    wrap.addEventListener('pointercancel', endDrag)

    // After a drag, swallow the click so it doesn't navigate a link
    wrap.addEventListener('click', (e: MouseEvent) => {
      if (moved > 5) {
        e.preventDefault()
        e.stopPropagation()
      }
      moved = 0
    }, true)

    // Touch: native scroll moves it; just manage pause state
    wrap.addEventListener('touchstart', () => { paused = true }, { passive: true })
    wrap.addEventListener('touchend', scheduleResume)
    wrap.addEventListener('wheel', () => { paused = true; scheduleResume() }, { passive: true })

    requestAnimationFrame(frame)
  }

  // Show loading state
  const loading = document.createElement('span')
  loading.className = 'nt-loading'
  loading.textContent = 'Cargando titulares...'
  track.appendChild(loading)

  fetch('/api/news-ticker.json')
    .then(r => r.ok ? r.json() : Promise.reject(r.status))
    .then((articles: { title: string; link: string }[]) => {
      renderTicker(track, articles.length ? articles : FALLBACK)
    })
    .catch(() => renderTicker(track, FALLBACK))
})()
</script>
