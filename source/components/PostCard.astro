---
import { SITE } from '../config'

interface Props {
  title: string
  description: string
  pubDate: Date
  category: string
  slug: string
  heroImage?: string
  readingTime: string
  featured?: boolean
}

const { title, description, pubDate, category, slug, heroImage, readingTime, featured = false } = Astro.props

const formattedDate = pubDate.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
})

const postUrl = `${SITE.url}/${slug}/`
const shareX = `https://twitter.com/intent/tweet?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(title)}`
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`

// Icono y gradiente por categoría
const categoryKey = category.toLowerCase().replace(/\s+/g, '-')

type CategoryConfig = { gradient: string; icon: string }

const categoryMap: Record<string, CategoryConfig> = {
  'modelos': {
    gradient: 'linear-gradient(135deg, #1a1035 0%, #2d1b69 100%)',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="10" stroke="#A78BFA" stroke-width="2"/>
      <circle cx="24" cy="24" r="3" fill="#A78BFA"/>
      <line x1="24" y1="8" x2="24" y2="14" stroke="#A78BFA" stroke-width="2" stroke-linecap="round"/>
      <line x1="24" y1="34" x2="24" y2="40" stroke="#A78BFA" stroke-width="2" stroke-linecap="round"/>
      <line x1="8" y1="24" x2="14" y2="24" stroke="#A78BFA" stroke-width="2" stroke-linecap="round"/>
      <line x1="34" y1="24" x2="40" y2="24" stroke="#A78BFA" stroke-width="2" stroke-linecap="round"/>
      <line x1="12.7" y1="12.7" x2="17" y2="17" stroke="#A78BFA" stroke-width="2" stroke-linecap="round"/>
      <line x1="31" y1="31" x2="35.3" y2="35.3" stroke="#A78BFA" stroke-width="2" stroke-linecap="round"/>
      <line x1="35.3" y1="12.7" x2="31" y2="17" stroke="#A78BFA" stroke-width="2" stroke-linecap="round"/>
      <line x1="17" y1="31" x2="12.7" y2="35.3" stroke="#A78BFA" stroke-width="2" stroke-linecap="round"/>
    </svg>`,
  },
  'inteligencia-artificial': {
    gradient: 'linear-gradient(135deg, #0f1f35 0%, #0e3460 100%)',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="10" y="14" width="28" height="20" rx="4" stroke="#60A5FA" stroke-width="2"/>
      <circle cx="17" cy="22" r="2.5" fill="#60A5FA"/>
      <circle cx="24" cy="22" r="2.5" fill="#60A5FA"/>
      <circle cx="31" cy="22" r="2.5" fill="#60A5FA"/>
      <line x1="17" y1="27" x2="31" y2="27" stroke="#60A5FA" stroke-width="2" stroke-linecap="round"/>
      <line x1="16" y1="10" x2="16" y2="14" stroke="#60A5FA" stroke-width="2" stroke-linecap="round"/>
      <line x1="24" y1="10" x2="24" y2="14" stroke="#60A5FA" stroke-width="2" stroke-linecap="round"/>
      <line x1="32" y1="10" x2="32" y2="14" stroke="#60A5FA" stroke-width="2" stroke-linecap="round"/>
      <line x1="16" y1="34" x2="16" y2="38" stroke="#60A5FA" stroke-width="2" stroke-linecap="round"/>
      <line x1="24" y1="34" x2="24" y2="38" stroke="#60A5FA" stroke-width="2" stroke-linecap="round"/>
      <line x1="32" y1="34" x2="32" y2="38" stroke="#60A5FA" stroke-width="2" stroke-linecap="round"/>
    </svg>`,
  },
  'conceptos': {
    gradient: 'linear-gradient(135deg, #0f2820 0%, #064e3b 100%)',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M24 8C18 8 13 13 13 19c0 4 2 7.5 5 9.5V32h12v-3.5c3-2 5-5.5 5-9.5 0-6-5-11-11-11z" stroke="#34D399" stroke-width="2" stroke-linejoin="round"/>
      <line x1="18" y1="36" x2="30" y2="36" stroke="#34D399" stroke-width="2" stroke-linecap="round"/>
      <line x1="20" y1="40" x2="28" y2="40" stroke="#34D399" stroke-width="2" stroke-linecap="round"/>
      <line x1="24" y1="8" x2="24" y2="5" stroke="#34D399" stroke-width="2" stroke-linecap="round"/>
      <line x1="36" y1="19" x2="39" y2="19" stroke="#34D399" stroke-width="2" stroke-linecap="round"/>
      <line x1="9" y1="19" x2="12" y2="19" stroke="#34D399" stroke-width="2" stroke-linecap="round"/>
    </svg>`,
  },
  'arquitectura': {
    gradient: 'linear-gradient(135deg, #1f1200 0%, #451a03 100%)',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <polyline points="8,34 18,18 28,26 38,12" stroke="#FB923C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <rect x="6" y="32" width="8" height="8" rx="1" stroke="#FB923C" stroke-width="2"/>
      <rect x="20" y="22" width="8" height="18" rx="1" stroke="#FB923C" stroke-width="2"/>
      <rect x="34" y="16" width="8" height="24" rx="1" stroke="#FB923C" stroke-width="2"/>
    </svg>`,
  },
  'herramientas': {
    gradient: 'linear-gradient(135deg, #1a1a0f 0%, #3d3d00 100%)',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M30 10a8 8 0 0 0-8 8c0 1 .2 2 .5 2.8L10 33a2.8 2.8 0 1 0 4 4l12.2-12.5c.8.3 1.8.5 2.8.5a8 8 0 1 0 1-15z" stroke="#FBBF24" stroke-width="2" stroke-linejoin="round"/>
      <circle cx="30" cy="18" r="2" fill="#FBBF24"/>
    </svg>`,
  },
  'ética': {
    gradient: 'linear-gradient(135deg, #1f0f2e 0%, #4c1d95 100%)',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M24 8l3 9h9l-7 5 3 9-8-6-8 6 3-9-7-5h9z" stroke="#C084FC" stroke-width="2" stroke-linejoin="round"/>
    </svg>`,
  },
  'tendencias': {
    gradient: 'linear-gradient(135deg, #0f1f2e 0%, #0c4a6e 100%)',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <polyline points="8,36 20,20 30,28 42,10" stroke="#38BDF8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <polyline points="34,10 42,10 42,18" stroke="#38BDF8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`,
  },
}

const defaultCategory: CategoryConfig = {
  gradient: 'linear-gradient(135deg, #1C1C2E 0%, #20183A 100%)',
  icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="24" cy="24" r="14" stroke="#A78BFA" stroke-width="2"/>
    <path d="M20 20c0-2.2 1.8-4 4-4s4 1.8 4 4c0 2-1.3 3.4-3 3.9V28" stroke="#A78BFA" stroke-width="2" stroke-linecap="round"/>
    <circle cx="24" cy="33" r="1.5" fill="#A78BFA"/>
  </svg>`,
}

const catConfig: CategoryConfig = categoryMap[categoryKey] ?? defaultCategory
---

<article class={`mona-card${featured ? ' mona-card--featured' : ''}`}>
  <a href={`/${slug}/`} class="mona-card-img-link" tabindex="-1" aria-hidden="true">
    <div class="mona-card-img" style={!heroImage ? `background: ${catConfig.gradient}` : ''}>
      {heroImage
        ? <img src={heroImage} alt={title} loading="lazy" width="800" height="400" />
        : <div class="cat-icon" set:html={catConfig.icon} />
      }
    </div>
  </a>
  <div class="mona-card-body">
    <span class="mona-badge">{category}</span>
    <h2 class="mona-title">
      <a href={`/${slug}/`}>{title}</a>
    </h2>
    <p class="mona-desc">{description}</p>
    <div class="mona-footer">
      <span class="mona-meta">{formattedDate} · {readingTime}</span>
      <div class="mona-actions">
        <div class="mona-share">
          <a href={shareX} target="_blank" rel="noopener noreferrer" class="share-icon" aria-label="Compartir en X">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={shareLinkedIn} target="_blank" rel="noopener noreferrer" class="share-icon" aria-label="Compartir en LinkedIn">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
        <a href={`/${slug}/`} class="mona-read">
          Leer
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 6h8M6 2l4 4-4 4"/></svg>
        </a>
      </div>
    </div>
  </div>
</article>

<style>
.mona-card {
  background: #13131F;
  display: flex;
  flex-direction: column;
  transition: background 0.15s;
}
.mona-card:hover { background: #1A1A2E; }

.mona-card--featured .mona-card-img { height: 200px; }
.mona-card--featured .mona-title a { font-size: 18px; }

.mona-card-img-link { display: block; }
.mona-card-img {
  width: 100%;
  height: 140px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.mona-card-img img { width: 100%; height: 100%; object-fit: cover; }

.cat-icon {
  width: 56px;
  height: 56px;
  opacity: 0.85;
}
.cat-icon svg {
  width: 100%;
  height: 100%;
}
.mona-card--featured .cat-icon {
  width: 72px;
  height: 72px;
}

.mona-card-body {
  padding: 16px 18px 16px;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.mona-badge {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #A78BFA;
  margin-bottom: 8px;
  display: block;
}

.mona-title {
  font-size: 14px;
  font-weight: 700;
  line-height: 1.4;
  color: #E8E8F0;
  margin-bottom: 8px;
  flex: 1;
}
.mona-title a {
  color: inherit;
  text-decoration: none;
  transition: color 0.15s;
}
.mona-title a:hover { color: #A78BFA; }

.mona-desc {
  font-size: 12px;
  color: #A0A0C0;
  line-height: 1.55;
  margin-bottom: 14px;
}

.mona-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid #2A2A40;
  gap: 8px;
}

.mona-meta {
  font-size: 11px;
  color: #505070;
  white-space: nowrap;
}

.mona-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.mona-share { display: flex; gap: 6px; }
.share-icon {
  width: 24px; height: 24px;
  border-radius: 4px;
  border: 1px solid #2A2A40;
  display: flex; align-items: center; justify-content: center;
  color: #505070;
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s;
}
.share-icon:hover { border-color: #6D28D9; color: #A78BFA; }

.mona-read {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  font-weight: 600;
  color: #A78BFA;
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.15s;
}
.mona-read:hover { color: #E8E8F0; }
</style>
