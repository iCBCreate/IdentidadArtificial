---
interface Props {
  title: string
  description: string
  href: string
  tag: string
  icon: string
  note?: string
}

const { title, description, href, tag, icon, note } = Astro.props
---

<article class="lab-card">
  <a href={href} class="lab-card-icon-link" tabindex="-1" aria-hidden="true">
    <div class="lab-card-icon" set:html={icon} />
  </a>
  <div class="lab-card-body">
    <span class="lab-badge">{tag}</span>
    <h3 class="lab-title"><a href={href}>{title}</a></h3>
    <p class="lab-desc">{description}</p>
    <div class="lab-footer">
      {note ? <span class="lab-note">{note}</span> : <span />}
      <a href={href} class="lab-open">
        Abrir demo
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 6h8M6 2l4 4-4 4"/></svg>
      </a>
    </div>
  </div>
</article>

<style>
.lab-card {
  background: #13131F;
  display: flex;
  flex-direction: column;
  transition: background 0.15s, box-shadow 0.2s ease;
}
.lab-card:hover { background: #1A1A2E; }

@media (hover: hover) {
  .lab-card:hover {
    box-shadow: inset 0 0 0 1px #A78BFA40;
  }
}

.lab-card-icon-link { display: block; }
.lab-card-icon {
  height: 110px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1A1A2E 0%, #13131F 100%);
  color: #A78BFA;
}
.lab-card-icon :global(svg) {
  width: 48px;
  height: 48px;
  opacity: 0.9;
}

.lab-card-body {
  padding: 16px 18px;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.lab-badge {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #A78BFA;
  margin-bottom: 8px;
  display: block;
}

.lab-title {
  font-size: 15px;
  font-weight: 700;
  line-height: 1.4;
  color: #E8E8F0;
  margin-bottom: 8px;
}
.lab-title a {
  color: inherit;
  text-decoration: none;
  transition: color 0.15s;
}
.lab-title a:hover { color: #A78BFA; }

.lab-desc {
  font-size: 12px;
  color: #A0A0C0;
  line-height: 1.55;
  margin-bottom: 14px;
  flex: 1;
}

.lab-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid #2A2A40;
  gap: 8px;
}

.lab-note {
  font-size: 11px;
  color: #9A9ABF;
  white-space: nowrap;
}

.lab-open {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  font-weight: 600;
  color: #A78BFA;
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.15s;
}
.lab-open:hover { color: #E8E8F0; }
</style>
