---
import BaseLayout from './BaseLayout.astro'
import { SITE } from '../config'

interface Props {
  title: string
  description: string
  image?: string
  jsonLd?: object | object[]
  eyebrow?: string
  heading: string
  subtitle: string
}

const { title, description, image, jsonLd, eyebrow = 'Laboratorio', heading, subtitle } = Astro.props

const isIndex = Astro.url.pathname.replace(/\/$/, '') === '/laboratorio'

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: isIndex
    ? [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Laboratorio' },
      ]
    : [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
        { '@type': 'ListItem', position: 2, name: 'Laboratorio', item: `${SITE.url}/laboratorio/` },
        { '@type': 'ListItem', position: 3, name: heading },
      ],
}

const allJsonLd = [breadcrumbSchema, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])]
---

<BaseLayout title={title} description={description} image={image} jsonLd={allJsonLd}>
  <section class="page-hero">
    <nav class="lab-breadcrumb" aria-label="Breadcrumb">
      <a href="/" aria-label="Inicio">⌂</a>
      <span class="sep">›</span>
      {isIndex
        ? <span class="current">Laboratorio</span>
        : <>
            <a href="/laboratorio/">Laboratorio</a>
            <span class="sep">›</span>
            <span class="current">{heading}</span>
          </>
      }
    </nav>
    <p class="page-eyebrow">{eyebrow}</p>
    <h1>{heading}</h1>
    <p class="page-subtitle">{subtitle}</p>
    <p class="lab-disclaimer">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      100% en tu navegador: nada de lo que escribas sale de tu dispositivo.
    </p>
  </section>

  <div class="page-body">
    <slot />
  </div>
</BaseLayout>

<style>
.page-hero {
  max-width: 64rem;
  margin: 0 auto;
  padding: 40px 24px 26px;
}

.lab-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: #A0A0C0;
  margin-bottom: 24px;
}
.lab-breadcrumb a { color: #A0A0C0; text-decoration: none; transition: color 0.15s; }
.lab-breadcrumb a:hover { color: #A78BFA; }
.lab-breadcrumb .sep { color: #3A3A54; }
.lab-breadcrumb .current { color: #E8E8F0; }

.page-eyebrow {
  color: #A78BFA;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
  margin: 0 0 10px;
}

h1 {
  color: #E8E8F0;
  font-size: clamp(34px, 6vw, 58px);
  font-weight: 900;
  line-height: 1;
  margin-top: 10px;
}

.page-subtitle {
  display: block;
  max-width: 680px;
  color: #A0A0C0;
  font-size: 16px;
  line-height: 1.7;
  margin-top: 16px;
}

.lab-disclaimer {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  margin-top: 18px;
  padding: 6px 12px;
  border: 1px solid #2A2A40;
  border-radius: 999px;
  color: #34D399;
  font-size: 12px;
  font-weight: 600;
}

.page-body {
  max-width: 64rem;
  margin: 0 auto;
  padding: 16px 24px 48px;
}
</style>
