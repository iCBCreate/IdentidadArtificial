---
import BaseLayout from './BaseLayout.astro'
import GenerationDossier from '../components/GenerationDossier.astro'
import PostInsights from '../components/PostInsights.astro'
import SemanticConnections from '../components/SemanticConnections.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import RelatedPosts from '../components/RelatedPosts.astro'
import { Image, getImage } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { SITE } from '../config'
import { categoryToSlug, type BlogCategory } from '../lib/categories'
import { POST_INSIGHTS } from '../data/generated/post-insights'
import { KNOWLEDGE_MAP } from '../data/generated/knowledge-map'

interface Props {
  title: string
  description: string
  pubDate: Date
  category: BlogCategory
  heroImage?: ImageMetadata
  generatedBy: string
  generatedAt: Date
  promptBase: string
  humanReviewed: boolean
  correctionNote?: string
  reviewNotes?: string
  sourceQuality?: 'Alta' | 'Media' | 'Baja'
  confidenceLevel?: 'Alta' | 'Media' | 'Baja'
  claimsReviewed?: string[]
  readingTime: string
  slug: string
  allPosts: CollectionEntry<'blog'>[]
  calcReadingTime: (text: string) => string
  tags?: string[]
}

const {
  title,
  description,
  pubDate,
  category,
  heroImage,
  generatedBy,
  generatedAt,
  promptBase,
  humanReviewed,
  correctionNote,
  reviewNotes,
  sourceQuality,
  confidenceLevel,
  claimsReviewed,
  readingTime,
  slug,
  allPosts,
  calcReadingTime,
  tags = [],
} = Astro.props

const formattedDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const heroOgImage = heroImage
  ? await getImage({ src: heroImage, format: 'jpeg', width: 1200, height: 630, quality: 75 })
  : null
const ogImage = heroOgImage ? heroOgImage.src : `/og/${slug}.png`
const canonicalURL = new URL(`/${slug}/`, SITE.url).href
const insight = POST_INSIGHTS[slug as keyof typeof POST_INSIGHTS]
const semanticConnections = KNOWLEDGE_MAP.relatedByPost[slug as keyof typeof KNOWLEDGE_MAP.relatedByPost] ?? []

const CATEGORY_ABOUT: Record<string, { '@type': string; name: string; sameAs: string }> = {
  'Modelos': { '@type': 'Thing', name: 'Modelo de lenguaje', sameAs: 'https://es.wikipedia.org/wiki/Modelo_de_lenguaje' },
  'Inteligencia Artificial': { '@type': 'Thing', name: 'Inteligencia artificial', sameAs: 'https://es.wikipedia.org/wiki/Inteligencia_artificial' },
  'Conceptos': { '@type': 'Thing', name: 'Inteligencia artificial generativa', sameAs: 'https://es.wikipedia.org/wiki/Inteligencia_artificial_generativa' },
  'Arquitectura': { '@type': 'Thing', name: 'Red neuronal artificial', sameAs: 'https://es.wikipedia.org/wiki/Red_neuronal_artificial' },
  'Herramientas': { '@type': 'Thing', name: 'Inteligencia artificial generativa', sameAs: 'https://es.wikipedia.org/wiki/Inteligencia_artificial_generativa' },
  'Ética': { '@type': 'Thing', name: 'Ética de la inteligencia artificial', sameAs: 'https://es.wikipedia.org/wiki/%C3%89tica_de_la_inteligencia_artificial' },
  'Tendencias': { '@type': 'Thing', name: 'Inteligencia artificial generativa', sameAs: 'https://es.wikipedia.org/wiki/Inteligencia_artificial_generativa' },
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: new URL(ogImage, SITE.url).href,
  datePublished: pubDate.toISOString(),
  dateModified: generatedAt.toISOString(),
  author: {
    '@type': 'Person',
    name: SITE.author,
    url: `${SITE.url}/sobre/`,
    sameAs: [SITE.linkedin, SITE.github],
    description:
      'Autor especializado en inteligencia artificial generativa. Publica en identidadartificial.com análisis técnicos sobre modelos de lenguaje, agentes de IA y herramientas de IA generativa.',
    knowsAbout: [
      'Inteligencia artificial generativa',
      'Modelos de lenguaje (LLM)',
      'Agentes de IA',
      'Arquitectura de sistemas de IA',
      'Herramientas de IA generativa',
    ],
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', SITE.url).href,
      width: 48,
      height: 48,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
  articleSection: category,
  keywords: [category, ...tags].join(', '),
  inLanguage: 'es-ES',
  ...(CATEGORY_ABOUT[category] ? { about: [CATEGORY_ABOUT[category]] } : {}),
}

const faqSchema = insight?.faqs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: insight.faqs.map((faq: { question: string; answer: string }) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    }
  : null

const postJsonLd = [jsonLd, faqSchema].filter(Boolean)
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  type="article"
  jsonLd={postJsonLd}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={pubDate.toISOString()} />
    <meta property="article:modified_time" content={generatedAt.toISOString()} />
    <meta property="article:author" content={SITE.author} />
    <meta property="article:section" content={category} />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <article class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-10">
      <Breadcrumbs category={category} title={title} />
      <div class="flex items-center gap-2 mb-4 flex-wrap">
        <a href={`/categoria/${categoryToSlug(category)}/`} class="inline-block bg-[#6D28D9] text-white text-[9px] font-bold tracking-[1.5px] uppercase px-2 py-0.5 rounded-[3px] hover:bg-[#7C3AED] transition-colors">
          {category}
        </a>
        <span class="text-[#3A3A54]">·</span>
        <time class="text-xs text-[#A0A0C0]" datetime={pubDate.toISOString()}>
          {formattedDate}
        </time>
        <span class="text-[#3A3A54]">·</span>
        <span class="text-xs text-[#A0A0C0]">{readingTime}</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-4 text-[#E8E8F0]">
        {title}
      </h1>
      <p class="text-lg text-[#A0A0C0] mb-3">{description}</p>
      <p class="text-sm text-[#6A6A8A]">
        Por <a href="/sobre/" rel="author" class="text-[#A78BFA] hover:text-[#C4B5FD] transition-colors">{SITE.author}</a>
      </p>
    </header>

    {heroImage && (
      <Image
        src={heroImage}
        alt={title}
        class="w-full rounded-lg mb-10"
        loading="eager"
        fetchpriority="high"
        width={1200}
        height={600}
        quality={30}
        format="avif"
        widths={[320, 400, 500, 600, 720, 800, 1000, 1200]}
        sizes="(max-width: 640px) 100vw, (max-width: 768px) 100vw, 768px"
      />
    )}

    <div class="prose prose-lg max-w-none
      prose-headings:font-bold
      prose-headings:text-[#E8E8F0]
      prose-p:text-[#C8C8E0]
      prose-a:text-[#A78BFA] prose-a:no-underline hover:prose-a:underline
      prose-code:font-mono prose-code:text-sm prose-code:text-[#E8E8F0]
      prose-pre:bg-[#24243A]
      prose-li:text-[#C8C8E0]
      prose-strong:text-[#E8E8F0]">
      <slot />
    </div>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-10 mb-2">
        {tags.map(tag => (
          <a
            href={`/tag/${tag}/`}
            class="text-[11px] font-medium text-[#A78BFA] border border-[#3A2A5A] bg-[#1C1C2E] px-2.5 py-1 rounded-full hover:bg-[#2A1A4A] hover:border-[#6D28D9] transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    <RelatedPosts
      currentSlug={slug}
      category={category}
      allPosts={allPosts}
      calcReadingTime={calcReadingTime}
    />

    <SemanticConnections items={semanticConnections} />

    <PostInsights insight={insight} />

    <GenerationDossier
      generatedBy={generatedBy}
      generatedAt={generatedAt}
      promptBase={promptBase}
      humanReviewed={humanReviewed}
      correctionNote={correctionNote}
      reviewNotes={reviewNotes}
      sourceQuality={sourceQuality}
      confidenceLevel={confidenceLevel}
      claimsReviewed={claimsReviewed}
    />
  </article>
</BaseLayout>
