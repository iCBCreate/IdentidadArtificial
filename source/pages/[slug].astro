---
import { getCollection, render } from 'astro:content'
import PostLayout from '../layouts/PostLayout.astro'
import { calcReadingTime } from '../lib/posts'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }))
}

const { post, allPosts } = Astro.props
const { Content } = await render(post)
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  category={post.data.category}
  heroImage={post.data.heroImage}
  generatedBy={post.data.generatedBy}
  generatedAt={post.data.generatedAt}
  promptBase={post.data.promptBase}
  humanReviewed={post.data.humanReviewed}
  correctionNote={post.data.correctionNote}
  reviewNotes={post.data.reviewNotes}
  sourceQuality={post.data.sourceQuality}
  confidenceLevel={post.data.confidenceLevel}
  claimsReviewed={post.data.claimsReviewed}
  readingTime={calcReadingTime(post.body ?? '')}
  slug={post.id}
  allPosts={allPosts}
  calcReadingTime={calcReadingTime}
  tags={post.data.tags}
>
  <Content />
</PostLayout>
