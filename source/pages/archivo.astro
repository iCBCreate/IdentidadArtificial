---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import PostCard from '../components/PostCard.astro'
import Pagination from '../components/Pagination.astro'

const PAGE_SIZE = 6

function calcReadingTime(text: string): string {
  const words = text.trim().split(/\s+/).length
  const minutes = Math.ceil(words / 200)
  return `${minutes} min`
}

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE)
const posts = allPosts.slice(0, PAGE_SIZE)
const categories = [...new Set(allPosts.map(p => p.data.category))]

const pills = [
  ['modelos', 'conceptos', 'arquitectura', 'herramientas', 'inteligencia artificial', 'tendencias', 'ética'],
  ['Claude', 'GPT-4o', 'Gemini', 'RAG', 'agentes', 'contexto', 'tokens', 'embeddings', 'fine-tuning'],
]
---

<BaseLayout
  title="Archivo"
  description="Todos los artículos publicados en Identidad Artificial."
>
  <!-- Header visual -->
  <section class="archivo-hero">
    <div class="pills-bg" aria-hidden="true">
      {pills.map((row, i) => (
        <div class={`pill-row pill-row-${i % 2 === 0 ? 'left' : 'right'}`}>
          {[...row, ...row, ...row, ...row].map(pill => (
            <span class="pill">{pill}</span>
          ))}
        </div>
      ))}
    </div>
    <div class="pills-overlay"></div>
    <div class="archivo-hero-content">
      <span class="archivo-eyebrow">Identidad Artificial</span>
      <h1 class="archivo-title">Archivo</h1>
      <p class="archivo-count">
        <span class="count-num">{allPosts.length}</span>
        {allPosts.length === 1 ? 'artículo publicado' : 'artículos publicados'}
      </p>
      <div class="cats-row">
        {categories.map(cat => (
          <span class="cat-pill">{cat}</span>
        ))}
      </div>
    </div>
  </section>

  <div class="archivo-body">
    <h2 class="section-label">Todos los artículos</h2>

    <div class="cards-grid">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          slug={post.id}
          heroImage={post.data.heroImage}
          readingTime={calcReadingTime(post.body ?? '')}
          featured={false}
          priority={false}
        />
      ))}
    </div>

    {totalPages > 1 && (
      <Pagination
        currentPage={1}
        totalPages={totalPages}
        totalPosts={allPosts.length}
        baseUrl="/archivo/"
        paginaUrl="/archivo/pagina/"
      />
    )}
  </div>
</BaseLayout>

<style>
/* ── Hero ── */
.archivo-hero {
  position: relative;
  overflow: hidden;
  min-height: 220px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pills-bg {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  padding: 20px 0;
  pointer-events: none;
  user-select: none;
}

.pill-row {
  display: flex;
  gap: 10px;
  white-space: nowrap;
  width: max-content;
}
.pill-row-left  { animation: scrollLeft  30s linear infinite; }
.pill-row-right { animation: scrollRight 24s linear infinite; }

@keyframes scrollLeft  { from { transform: translateX(0); }          to { transform: translateX(-25%); } }
@keyframes scrollRight { from { transform: translateX(-25%); }       to { transform: translateX(0); } }

.pill {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: 20px;
  border: 1px solid rgba(167, 139, 250, 0.18);
  background: rgba(109, 40, 217, 0.07);
  color: rgba(160, 160, 192, 0.5);
  font-size: 11px;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.pills-overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 70% 90% at 50% 50%,
    rgba(28, 28, 44, 0.96) 0%,
    rgba(28, 28, 44, 0.70) 55%,
    transparent 100%
  );
  pointer-events: none;
}

.archivo-hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 40px 24px;
}

.archivo-eyebrow {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #A78BFA;
  margin-bottom: 10px;
}

.archivo-title {
  font-size: clamp(32px, 6vw, 48px);
  font-weight: 800;
  letter-spacing: -2px;
  color: #E8E8F0;
  line-height: 1;
  margin-bottom: 10px;
}

.archivo-count {
  font-size: 14px;
  color: #6A6A8A;
  margin-bottom: 18px;
}
.count-num {
  font-weight: 700;
  color: #A78BFA;
}

.cats-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
}

.cat-pill {
  font-size: 11px;
  font-weight: 500;
  padding: 4px 12px;
  border-radius: 20px;
  border: 1px solid rgba(109, 40, 217, 0.4);
  color: #A78BFA;
  background: rgba(109, 40, 217, 0.08);
}

/* ── Body ── */
.archivo-body {
  max-width: 64rem;
  margin: 0 auto;
  padding: 2.5rem 1.5rem 4rem;
}

.section-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #A0A0C0;
  padding-bottom: 12px;
  border-bottom: 1px solid #2A2A40;
  margin-bottom: 24px;
}

/* ── Cards grid (igual al Home) ── */
.cards-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1px;
  background: #2A2A40;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 8px;
}

@media (max-width: 768px) {
  .cards-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .cards-grid { grid-template-columns: 1fr; }
}
</style>
