---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Aviso Legal"
  description="Información legal sobre el titular del sitio, propiedad intelectual, protección de datos y condiciones de uso de Identidad Artificial."
>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold mb-2 text-[#E8E8F0]">Aviso Legal</h1>
    <p class="text-sm text-[#606080] mb-10">Última actualización: abril de 2026</p>

    <div class="prose prose-lg max-w-none
      prose-headings:font-bold prose-headings:text-[#E8E8F0]
      prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4
      prose-p:text-[#C8C8E0] prose-p:leading-relaxed
      prose-li:text-[#C8C8E0]
      prose-strong:text-[#E8E8F0]
      prose-a:text-[#A78BFA] prose-a:no-underline hover:prose-a:underline">

      <h2>1. Información general</h2>
      <p>
