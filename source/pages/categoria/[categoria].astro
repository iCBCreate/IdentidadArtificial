---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PostCard from '../../components/PostCard.astro'
import { SITE } from '../../config'
import { BLOG_CATEGORIES, CATEGORY_CONFIG, categoryToSlug, type BlogCategory } from '../../lib/categories'
import { getSortedPosts, calcReadingTime } from '../../lib/posts'

export async function getStaticPaths() {
  const allPosts = await getSortedPosts()
  return BLOG_CATEGORIES.map(category => ({
    params: { categoria: categoryToSlug(category) },
    props: {
      category,
      posts: allPosts.filter(p => p.data.category === category),
    },
  }))
}

interface Props {
  category: BlogCategory
  posts: Awaited<ReturnType<typeof getSortedPosts>>
}

const { category, posts } = Astro.props
const { categoria } = Astro.params
const catConfig = CATEGORY_CONFIG[category]
const canonicalURL = new URL(`/categoria/${categoria}/`, SITE.url).href

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${category} — ${SITE.name}`,
  description: `Artículos sobre ${category} en Identidad Artificial. Análisis técnicos sobre IA en español con revisión experta.`,
  url: canonicalURL,
  inLanguage: 'es',
  isAccessibleForFree: true,
  author: {
    '@type': 'Person',
    name: SITE.author,
    url: `${SITE.url}/sobre/`,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  mainEntity: {
    '@type': 'ItemList',
    name: `Artículos sobre ${category}`,
    numberOfItems: posts.length,
    itemListElement: posts.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: post.data.title,
      url: `${SITE.url}/${post.id}/`,
    })),
  },
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: category, item: canonicalURL },
  ],
}
---

<BaseLayout
  title={`${category} — IA en español`}
  description={`Artículos sobre ${category} en Identidad Artificial. Análisis técnicos sobre IA en español con revisión experta.`}
  jsonLd={[jsonLd, breadcrumbSchema]}
>
  <section class="cat-hero" style={`background: ${catConfig.gradient}`}>
    <div class="cat-icon" set:html={catConfig.icon} />
    <span class="cat-eyebrow">Categoría</span>
    <h1 class="cat-title">{category}</h1>
    <p class="cat-count">
      <span class="count-num">{posts.length}</span>
      {posts.length === 1 ? ' artículo' : ' artículos'}
    </p>
  </section>

  <div class="cat-body">
    <nav class="cat-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span>›</span>
      <span>{category}</span>
    </nav>

    {posts.length > 0 ? (
      <div class="cards-grid">
        {posts.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            heroImage={post.data.heroImage}
            readingTime={calcReadingTime(post.body ?? '')}
            featured={false}
            priority={i === 0}
          />
        ))}
      </div>
    ) : (
      <p class="empty-msg">No hay artículos en esta categoría todavía.</p>
    )}

    <p class="back-link"><a href="/archivo/">← Todos los artículos</a></p>
  </div>
</BaseLayout>

<style>
.cat-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px 40px;
  text-align: center;
  position: relative;
}

.cat-icon {
  width: 56px;
  height: 56px;
  margin-bottom: 16px;
  opacity: 0.9;
}
.cat-icon :global(svg) {
  width: 100%;
  height: 100%;
}

.cat-eyebrow {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin-bottom: 8px;
}

.cat-title {
  font-size: clamp(28px, 5vw, 42px);
  font-weight: 800;
  letter-spacing: -1.5px;
  color: #E8E8F0;
  line-height: 1;
  margin-bottom: 10px;
}

.cat-count {
  font-size: 13px;
  color: rgba(255,255,255,0.45);
}
.count-num {
  font-weight: 700;
  color: rgba(255,255,255,0.7);
}

.cat-body {
  max-width: 64rem;
  margin: 0 auto;
  padding: 2rem 1.5rem 4rem;
}

.cat-breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: #6A6A8A;
  margin-bottom: 24px;
}
.cat-breadcrumb a {
  color: #A78BFA;
  text-decoration: none;
  transition: color 0.15s;
}
.cat-breadcrumb a:hover { color: #E8E8F0; }

.cards-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1px;
  background: #2A2A40;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 32px;
}

@media (max-width: 768px) {
  .cards-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .cards-grid { grid-template-columns: 1fr; }
}

.empty-msg {
  text-align: center;
  color: #6A6A8A;
  padding: 48px 0;
  font-size: 14px;
}

.back-link {
  margin-top: 8px;
}
.back-link a {
  font-size: 13px;
  color: #A78BFA;
  text-decoration: none;
  transition: color 0.15s;
}
.back-link a:hover { color: #E8E8F0; }
</style>
