---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE } from '../config'

const pills = [
  ['Astro 6', 'static output', 'Cloudflare Workers', 'MDX', 'Tailwind v4', 'Sharp', 'WebP srcset'],
  ['JSON-LD', 'sitemap XML', 'Open Graph', 'robots.txt', 'llms.txt', 'RSS feed', 'GEO'],
  ['Satori', 'OG images', 'wrangler deploy', 'build pipeline', 'frontmatter Zod', 'TypeScript strict'],
]

const stack = [
  { name: 'Astro 6', desc: 'Output estático, cero JS al cliente por defecto', icon: '🚀' },
  { name: 'Tailwind CSS v4', desc: 'Estilos utilitarios, CSS inlinado en build', icon: '🎨' },
  { name: 'MDX', desc: 'Posts en Markdown con soporte de componentes', icon: '📝' },
  { name: 'Cloudflare', desc: 'Workers + Assets, despliegue en cada push a main', icon: '☁️' },
  { name: 'Modelos de IA', desc: 'Claude, GPT-4o, Gemini… registrado en metadatos', icon: '🤖' },
  { name: 'Satori + resvg', desc: 'Imágenes Open Graph generadas en build time', icon: '🖼️' },
  { name: 'Sharp', desc: 'Optimización hero: WebP + srcset automático', icon: '⚡' },
  { name: 'GitHub', desc: 'Repositorio público, fuente de verdad', icon: '🔗' },
]

const pipeline = [
  { n: '1', label: 'Definir tema del artículo' },
  { n: '2', label: 'El modelo recibe prompt + guía de estilo del repo' },
  { n: '3', label: 'El modelo genera el .mdx completo con frontmatter' },
  { n: '4', label: 'Revisión humana obligatoria antes de publicar' },
  { n: '5', label: 'Commit y push al repositorio GitHub' },
  { n: '6', label: 'Cloudflare detecta el push y ejecuta npm run build' },
  { n: '7', label: 'generate-og.mjs genera PNG 1200×630 por post' },
  { n: '8', label: 'Sharp convierte imágenes hero a WebP + srcset' },
  { n: '9', label: 'Astro compila el sitio estático con todos los assets' },
  { n: '10', label: 'Wrangler despliega a la red de Cloudflare en ~90s' },
]

const geo = [
  { label: 'Open Graph + Twitter Card', desc: 'Imagen OG por post generada en build-time con título, categoría y fecha' },
  { label: 'JSON-LD (schema.org)', desc: 'Metadatos estructurados tipo Article para Google y otros motores' },
  { label: 'Sitemap XML', desc: 'Generado automáticamente por @astrojs/sitemap' },
  { label: 'robots.txt', desc: 'Indexación total por buscadores y bots de IA' },
  { label: 'llms.txt', desc: 'Estándar emergente para indicar a sistemas de IA cómo indexar el contenido' },
  { label: 'RSS', desc: 'Feed estándar para lectores y agregadores' },
]

const security = [
  { label: 'HSTS', desc: 'Fuerza HTTPS durante 1 año con preload' },
  { label: 'X-Frame-Options: DENY', desc: 'Previene clickjacking' },
  { label: 'Content-Security-Policy', desc: 'Restringe el origen de scripts, estilos y fuentes' },
  { label: 'X-Content-Type-Options', desc: 'Evita MIME sniffing' },
  { label: 'Referrer-Policy', desc: 'Limita la información de referencia enviada' },
  { label: 'Permissions-Policy', desc: 'Deshabilita acceso a cámara, micrófono y geolocalización' },
]
---

<BaseLayout
  title="Cómo funciona"
  description="El pipeline completo: stack, flujo de generación, SEO/GEO, infraestructura de despliegue y decisiones de diseño de Identidad Artificial."
>
  <!-- Mini hero -->
  <section class="cf-hero">
    <div class="pills-bg" aria-hidden="true">
      {pills.map((row, i) => (
        <div class={`pill-row pill-row-${i % 2 === 0 ? 'left' : 'right'}`}>
          {[...row, ...row, ...row].map(pill => (
            <span class="pill">{pill}</span>
          ))}
        </div>
      ))}
    </div>
    <div class="pills-overlay"></div>
    <div class="cf-hero-content">
      <span class="cf-eyebrow">Transparencia radical</span>
      <h1 class="cf-title">
        Cómo <span class="accent">funciona</span>
      </h1>
      <p class="cf-subtitle">
        Stack, pipeline de publicación, SEO/GEO<br />e infraestructura de despliegue.
      </p>
    </div>
  </section>

  <div class="cf-body">

    <!-- Stack -->
    <div class="section-label">El stack</div>
    <div class="stack-grid">
      {stack.map((item, i) => (
        <div class="stack-card fade-up" style={`animation-delay: ${i * 0.04}s`}>
          <span class="stack-icon" aria-hidden="true">{item.icon}</span>
          <div>
            <div class="stack-name">{item.name}</div>
            <div class="stack-desc">{item.desc}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Pipeline -->
    <div class="section-label">El pipeline de publicación</div>
    <div class="pipeline fade-up" style="animation-delay: 0.05s">
      {pipeline.map((step) => (
        <div class="pipeline-step">
          <div class="step-num">{step.n}</div>
          <div class="step-label">{step.label}</div>
        </div>
      ))}
    </div>

    <!-- Repo structure -->
    <div class="section-label">Estructura del repositorio</div>
    <div class="code-block fade-up" style="animation-delay: 0.05s">
      <pre><code>{`identidad-artificial/
├── source/
│   ├── assets/post/      ← Imágenes hero de los posts
│   ├── content/blog/     ← Posts en .mdx
│   ├── components/       ← Header, Footer, PostCard, TransparencyBlock…
│   ├── layouts/          ← BaseLayout, PostLayout
│   ├── pages/            ← Rutas del sitio
│   └── styles/           ← CSS global
├── scripts/
│   └── generate-og.mjs   ← Generador de imágenes OG (prebuild)
├── docs/
│   └── guia-crear-post.md ← Instrucciones para generar posts con cualquier modelo
├── public/
│   ├── fonts/            ← Inter TTF para satori
│   ├── og/               ← Imágenes OG generadas (no en git)
│   └── _headers          ← Cabeceras de seguridad para Cloudflare
├── wrangler.toml         ← Configuración del despliegue
└── astro.config.mjs`}</code></pre>
    </div>

    <!-- Frontmatter -->
    <div class="section-label">Frontmatter de cada post</div>
    <p class="cf-note fade-up" style="animation-delay: 0.03s">
      Metadatos de transparencia validados con Zod en build time y mostrados al pie de cada artículo:
    </p>
    <div class="code-block fade-up" style="animation-delay: 0.08s">
      <pre><code>{`---
title: 'Título del post'
description: 'Descripción para SEO'
pubDate: 2026-04-21
category: 'Modelos'
tags: ['llm', 'agentes']
generatedBy: 'claude-sonnet-4-6'
generatedAt: '2026-04-21T10:00:00Z'
promptBase: 'El prompt que se usó para generar este post'
humanReviewed: true
heroImage: '../../assets/post/imagen-del-post.jpg'  # opcional
correctionNote: 'Texto si el post corrige errores de una versión anterior.'  # opcional
---`}</code></pre>
    </div>
    <p class="cf-note fade-up" style="animation-delay: 0.05s">
      <code>correctionNote</code> aparece como bloque de aviso visible en el post cuando se publica una corrección.
      <code>heroImage</code> referencia una imagen local que Astro optimiza y convierte a WebP en build time.
    </p>

    <!-- SEO/GEO -->
    <div class="section-label">Infraestructura SEO y GEO</div>
    <p class="cf-note fade-up" style="animation-delay: 0.03s">
      GEO (Generative Engine Optimization) es el equivalente del SEO para motores de respuesta como ChatGPT, Perplexity o Claude. El sitio está preparado para ambos:
    </p>
    <div class="geo-grid">
      {geo.map((item, i) => (
        <div class="geo-card fade-up" style={`animation-delay: ${i * 0.04}s`}>
          <div class="geo-label">{item.label}</div>
          <div class="geo-desc">{item.desc}</div>
        </div>
      ))}
    </div>

    <!-- Seguridad -->
    <div class="section-label">Seguridad</div>
    <p class="cf-note fade-up" style="animation-delay: 0.03s">
      Cabeceras HTTP aplicadas a nivel de Cloudflare via <code>public/_headers</code>:
    </p>
    <div class="security-list fade-up" style="animation-delay: 0.08s">
      {security.map((item) => (
        <div class="security-item">
          <code class="security-label">{item.label}</code>
          <span class="security-desc">{item.desc}</span>
        </div>
      ))}
    </div>

    <!-- Variables de entorno -->
    <div class="section-label">Variables de entorno</div>
    <div class="env-card fade-up" style="animation-delay: 0.05s">
      <span class="env-icon" aria-hidden="true">🔒</span>
      <p>Ninguna credencial está en el repositorio. Las variables de entorno se gestionan exclusivamente en el panel de Cloudflare.</p>
    </div>

    <!-- CTAs -->
    <div class="cf-cta fade-up" style="animation-delay: 0.1s">
      <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="btn-primary">Ver repositorio</a>
      <a href="/" class="btn-secondary">Últimas entradas →</a>
    </div>

  </div>
</BaseLayout>

<style>
/* ── Hero ── */
.cf-hero {
  position: relative;
  overflow: hidden;
  min-height: 240px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pills-bg {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 20px 0;
  pointer-events: none;
  user-select: none;
}

.pill-row {
  display: flex;
  gap: 10px;
  white-space: nowrap;
  width: max-content;
}
.pill-row-left  { animation: scrollLeft  22s linear infinite; }
.pill-row-right { animation: scrollRight 28s linear infinite; }
.pill-row:nth-child(3) { animation-duration: 18s; }

@keyframes scrollLeft  { from { transform: translateX(0); }          to { transform: translateX(-33.333%); } }
@keyframes scrollRight { from { transform: translateX(-33.333%); }   to { transform: translateX(0); } }

.pill {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: 20px;
  border: 1px solid rgba(167, 139, 250, 0.18);
  background: rgba(109, 40, 217, 0.07);
  color: rgba(160, 160, 192, 0.5);
  font-size: 11px;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.pills-overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 60% 80% at 50% 50%,
    rgba(28, 28, 44, 0.95) 0%,
    rgba(28, 28, 44, 0.65) 55%,
    transparent 100%
  );
  pointer-events: none;
}

.cf-hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 44px 24px;
}

.cf-eyebrow {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #A78BFA;
  margin-bottom: 14px;
}

.cf-title {
  font-size: clamp(28px, 5vw, 40px);
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -1.5px;
  color: #E8E8F0;
  margin-bottom: 12px;
}
.accent { color: #A78BFA; }

.cf-subtitle {
  font-size: 15px;
  color: #A0A0C0;
  line-height: 1.65;
}

/* ── Body ── */
.cf-body {
  max-width: 56rem;
  margin: 0 auto;
  padding: 3rem 1.5rem 4rem;
}

.section-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #A0A0C0;
  padding-bottom: 12px;
  border-bottom: 1px solid #2A2A40;
  margin-bottom: 20px;
  margin-top: 48px;
}
.section-label:first-child { margin-top: 0; }

.cf-note {
  font-size: 14px;
  color: #C8C8E0;
  line-height: 1.7;
  margin-bottom: 16px;
}
.cf-note code {
  font-family: monospace;
  font-size: 12px;
  color: #E8E8F0;
  background: #24243A;
  padding: 2px 6px;
  border-radius: 4px;
}

/* ── Stack ── */
.stack-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: #2A2A40;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  overflow: hidden;
}

.stack-card {
  background: #1C1C2C;
  padding: 18px 16px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.stack-icon {
  font-size: 18px;
  flex-shrink: 0;
  margin-top: 1px;
  filter: grayscale(0.2);
}

.stack-name {
  font-size: 13px;
  font-weight: 700;
  color: #E8E8F0;
  margin-bottom: 4px;
}

.stack-desc {
  font-size: 12px;
  color: #8080A0;
  line-height: 1.5;
}

/* ── Pipeline ── */
.pipeline {
  border: 1px solid #2A2A40;
  border-radius: 8px;
  overflow: hidden;
}

.pipeline-step {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 13px 20px;
  border-bottom: 1px solid #2A2A40;
  background: #1C1C2C;
}
.pipeline-step:last-child { border-bottom: none; }

.step-num {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(109, 40, 217, 0.2);
  border: 1px solid rgba(167, 139, 250, 0.2);
  color: #A78BFA;
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-label {
  font-size: 13px;
  color: #C8C8E0;
}

/* ── Code block ── */
.code-block {
  background: #14142A;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  overflow: auto;
  margin-bottom: 8px;
}

.code-block pre {
  margin: 0;
  padding: 20px 24px;
}

.code-block code {
  font-family: 'ui-monospace', 'Cascadia Code', 'Fira Code', monospace;
  font-size: 12px;
  line-height: 1.7;
  color: #C8C8E0;
  white-space: pre;
}

/* ── GEO ── */
.geo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: #2A2A40;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  overflow: hidden;
}

.geo-card {
  background: #1C1C2C;
  padding: 16px 20px;
}

.geo-label {
  font-size: 13px;
  font-weight: 600;
  color: #E8E8F0;
  margin-bottom: 4px;
}

.geo-desc {
  font-size: 12px;
  color: #8080A0;
  line-height: 1.5;
}

/* ── Security ── */
.security-list {
  border: 1px solid #2A2A40;
  border-radius: 8px;
  overflow: hidden;
}

.security-item {
  display: flex;
  align-items: baseline;
  gap: 12px;
  padding: 12px 20px;
  border-bottom: 1px solid #2A2A40;
  background: #1C1C2C;
}
.security-item:last-child { border-bottom: none; }

.security-label {
  flex-shrink: 0;
  font-family: monospace;
  font-size: 11px;
  color: #A78BFA;
  background: rgba(109, 40, 217, 0.12);
  padding: 2px 8px;
  border-radius: 4px;
  border: 1px solid rgba(167, 139, 250, 0.15);
}

.security-desc {
  font-size: 13px;
  color: #A0A0C0;
}

/* ── Env card ── */
.env-card {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  background: #1C1C2C;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  padding: 20px 24px;
}

.env-icon { font-size: 20px; flex-shrink: 0; }

.env-card p {
  font-size: 14px;
  color: #C8C8E0;
  line-height: 1.7;
  margin: 0;
}

/* ── CTAs ── */
.cf-cta {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 48px;
}

.btn-primary {
  background: #6D28D9;
  color: #fff;
  font-size: 13px;
  font-weight: 600;
  padding: 10px 22px;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.15s;
}
.btn-primary:hover { background: #7C3AED; }

.btn-secondary {
  background: transparent;
  border: 1px solid #2E2E48;
  color: #A0A0C0;
  font-size: 13px;
  padding: 10px 22px;
  border-radius: 6px;
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s;
}
.btn-secondary:hover { border-color: #6D28D9; color: #E8E8F0; }

/* ── Animation ── */
.fade-up {
  opacity: 0;
  transform: translateY(8px);
  animation: fadeUp 0.4s forwards;
}
@keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

/* ── Mobile ── */
@media (max-width: 768px) {
  .stack-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .stack-grid { grid-template-columns: 1fr; }
  .geo-grid   { grid-template-columns: 1fr; }
  .security-item { flex-direction: column; gap: 6px; }
}
</style>
