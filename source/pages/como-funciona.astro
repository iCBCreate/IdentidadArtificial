---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE } from '../config'

const pills = [
  ['Astro 6', 'static output', 'Cloudflare Workers', 'MDX', 'tutoriales', 'Tailwind v4', 'Sharp', 'AVIF srcset'],
  ['JSON-LD', 'sitemap XML', 'Open Graph', 'robots.txt', 'llms.txt', 'llms-full.txt', 'RSS feed', 'GEO'],
  ['Satori', 'OG images', 'knowledge map', 'post insights', 'editorial radar', 'frontmatter Zod'],
  ['View Transitions', 'Speculation Rules', 'fetchpriority', 'font-size-adjust', 'text-wrap: balance', 'CLS 0'],
]

const stack = [
  { name: 'Astro 6', desc: 'Output estático con JavaScript mínimo para interacción', icon: '🚀', href: 'https://astro.build' },
  { name: 'Tailwind CSS v4', desc: 'Estilos utilitarios, CSS inlinado en build', icon: '🎨', href: 'https://tailwindcss.com' },
  { name: 'MDX', desc: 'Posts y tutoriales en Markdown con soporte de componentes', icon: '📝', href: 'https://mdxjs.com' },
  { name: 'Cloudflare Workers', desc: 'Workers + Assets, despliegue manual con wrangler', icon: '☁️', href: 'https://workers.cloudflare.com' },
  { name: 'Modelos de IA', desc: 'Claude, GPT-4o, Gemini… registrado en metadatos', icon: '🤖', href: 'https://claude.ai' },
  { name: 'Satori + resvg', desc: 'Imágenes Open Graph generadas en build time', icon: '🖼️', href: 'https://github.com/vercel/satori' },
  { name: 'Sharp', desc: 'Optimización hero: AVIF quality 30 + srcset automático (ahorro ~30% vs quality 50)', icon: '⚡', href: 'https://sharp.pixelplumbing.com' },
  { name: 'Datos derivados', desc: 'Mapa semántico, lecturas IA y radar editorial en build-time', icon: '🧠' },
]

const pipeline = [
  { n: '1', label: 'Definir tema del artículo o tutorial' },
  { n: '2', label: 'El modelo recibe prompt + guía de estilo del repo' },
  { n: '3', label: 'El modelo genera el .mdx completo con frontmatter' },
  { n: '4', label: 'Revisión humana obligatoria antes de publicar' },
  { n: '5', label: 'Commit y push al repositorio GitHub' },
  { n: '6', label: 'Se ejecuta npm run deploy desde la CLI (el despliegue es manual)' },
  { n: '7', label: 'build:data genera mapa semántico, lecturas IA y radar editorial' },
  { n: '8', label: 'generate-og.mjs genera PNG 1200×630 para el contenido publicado' },
  { n: '9', label: 'Sharp convierte imágenes hero locales a AVIF + srcset cuando existen' },
  { n: '10', label: 'Astro compila HTML estático, llms-full.txt, RSS y sitemap' },
  { n: '11', label: 'Wrangler despliega a la red de Cloudflare en ~90s' },
]

const aiSystem = [
  { label: 'Mapa semántico', desc: 'generate-knowledge-map.mjs extrae categorías, tags, empresas y conceptos para alimentar /mapa-ia/ y el bloque "Conecta con" de cada post.' },
  { label: 'Lecturas generadas', desc: 'generate-post-insights.mjs crea resumen ejecutivo, lectura técnica, puntos clave, glosario y FAQ por artículo sin llamar a una API en runtime.' },
  { label: 'Radar editorial', desc: 'generate-editorial-radar.mjs compara el corpus con temas técnicos pendientes y publica señales filtradas en /radar/.' },
  { label: 'Expediente IA', desc: 'Cada post muestra modelo, prompt base, revisión humana, confianza, calidad de fuentes, claims revisados y correcciones cuando existen.' },
]

const perf = [
  { label: 'View Transitions API', desc: 'Crossfade suave entre páginas del sitio. Se activa con @view-transition en CSS, respeta prefers-reduced-motion y degrada graciosamente en navegadores sin soporte.' },
  { label: 'Speculation Rules API', desc: 'Prefetch eager + prerender moderate de todos los enlaces internos. El navegador anticipa la siguiente página antes de que el usuario haga clic, consiguiendo navegación casi instantánea.' },
  { label: 'fetchpriority="high"', desc: 'La imagen hero del post destacado en portada lleva fetchpriority="high" para que el navegador la cargue antes que otras imágenes y mejore el LCP.' },
  { label: 'Sin forced reflow', desc: 'El tooltip del timeline usa visualViewport.width/height en lugar de window.innerWidth/Height. visualViewport no fuerza un layout flush durante la inicialización del módulo, eliminando 192ms de reflow en el critical path.' },
  { label: 'Aspect ratio alineado', desc: 'Las PostCard generan imágenes a 800×310 (ratio 2.58:1) igualando el ratio del contenedor .mona-card-img (140px alto × ~362px ancho). Elimina los píxeles descartados por object-fit: cover y reduce ~23% el peso de cada imagen de card.' },
  { label: 'font-size-adjust: from-font', desc: 'Sincroniza el x-height de la fuente de respaldo con Inter antes de que la webfont cargue, eliminando el CLS (Cumulative Layout Shift) visual durante el font swap.' },
  { label: 'text-wrap: balance / pretty', desc: 'Los títulos usan text-wrap: balance para distribuir líneas simétricamente. Los párrafos usan text-wrap: pretty para evitar huérfanos al final de párrafo.' },
]

const a11y = [
  { label: 'Skip link', desc: 'Enlace "Saltar al contenido principal" visible solo al recibir foco (tecla Tab). El <main> tiene tabindex="-1" para ser focusable programáticamente, siguiendo WCAG 2.4.1.' },
  { label: 'Atributo inert en menú móvil', desc: 'Al abrir el menú hamburger, se aplica inert a <main> y <footer>. El navegador elimina ambos del árbol de accesibilidad y del flujo de teclado sin necesidad de un focus trap JS manual.' },
  { label: ':focus-visible global', desc: 'Outline morado (#A78BFA) de 2px en todos los enlaces y botones al navegar con teclado. No afecta a usuarios de ratón. Complementa los estilos específicos de componentes como AITimeline.' },
  { label: 'Nav landmarks completos', desc: 'El footer envuelve sus enlaces en <nav aria-label="Legal y redes sociales"> para que lectores de pantalla anuncien el grupo. La paginación usa <nav aria-label="Paginación"> con aria-current="page" y aria-label en prev/next.' },
  { label: 'Indicador activo accesible por color', desc: 'El link activo en el menú móvil muestra borde izquierdo morado además del cambio de color, visible para usuarios con daltonismo que no perciban la diferencia de tono.' },
  { label: 'Hover solo con puntero fino', desc: 'El estado hover de las PostCard usa @media (hover: hover) para que solo se active en desktop con ratón. En móvil no hay estados hover falsos que confundan al usuario táctil.' },
]

const geo = [
  { label: 'Open Graph + Twitter Card', desc: 'og:image usa la heroImage del post convertida a JPEG 1200×630 quality 75 en build-time con getImage() de Astro — compatible con scrapers sociales que no leen AVIF. Si no hay heroImage, usa la tarjeta de texto PNG generada por Satori con título, categoría y fecha. og:url, og:locale es_ES y twitter:card summary_large_image en todas las páginas.' },
  { label: 'JSON-LD por tipo de página', desc: 'WebSite + Organization + Blog en home, TechArticle en /como-funciona/, Dataset en /mapa-ia/, CollectionPage + ItemList en /archivo/ y /radar/, Article en posts y tutoriales. Generados en build-time, en el HTML inicial — no requieren JS.' },
  { label: 'Person schema con sameAs', desc: 'Ignacio Cubelas como entidad en cada post: url apunta a /sobre/, sameAs enlaza LinkedIn y GitHub. Permite a sistemas de IA vincular el autor con su identidad real.' },
  { label: 'Sitemap XML', desc: 'Generado por @astrojs/sitemap con lastmod real de cada archivo fuente. Excluye páginas legales, paginación y posts retirados. /tutoriales/ incluye lastmod vía detección recursiva de subdirectorios.' },
  { label: 'robots.txt con todos los crawlers IA', desc: 'GPTBot, ChatGPT-User, PerplexityBot, ClaudeBot, Google-Extended, OAI-SearchBot, Bytespider, Applebot-Extended, CCBot, anthropic-ai — todos con Allow: /. Charset UTF-8 explícito en _headers.' },
  { label: 'llms.txt + llms-full.txt + RSL 1.0', desc: 'llms.txt lista artículos individuales con descripciones y declara permisos RSL 1.0 (indexing, training, citation required). llms-full.txt genera en runtime el corpus completo con texto íntegro de cada post.' },
  { label: 'Byline rel="author"', desc: 'Cada post muestra "Por Ignacio Cubelas" con rel="author" enlazado a /sobre/. Señal E-E-A-T visible en HTML — no solo en schema.' },
  { label: 'RSS', desc: 'Feed estándar para lectores y agregadores. Referenciado en <head> con rel="alternate" en todas las páginas.' },
]

const security = [
  { label: 'HSTS', desc: 'Fuerza HTTPS durante 1 año con preload' },
  { label: 'X-Frame-Options: DENY', desc: 'Previene clickjacking' },
  { label: 'Content-Security-Policy', desc: 'Restringe el origen de scripts, estilos y fuentes' },
  { label: 'X-Content-Type-Options', desc: 'Evita MIME sniffing' },
  { label: 'Referrer-Policy', desc: 'Limita la información de referencia enviada' },
  { label: 'Permissions-Policy', desc: 'Deshabilita acceso a cámara, micrófono y geolocalización' },
]

const techArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: 'Cómo funciona Identidad Artificial: stack, pipeline y despliegue',
  description: 'Documentación técnica del stack, pipeline editorial y arquitectura de Identidad Artificial: Astro 6, Cloudflare Workers, IA generativa y GEO.',
  url: `${SITE.url}/como-funciona/`,
  inLanguage: 'es',
  author: {
    '@type': 'Person',
    name: SITE.author,
    url: `${SITE.url}/sobre/`,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
  },
  keywords: ['Astro', 'Cloudflare Workers', 'IA generativa', 'pipeline editorial', 'LLMs', 'MDX', 'GEO', 'SEO'],
}
---

<BaseLayout
  title="Stack y pipeline del blog de IA — Cómo funciona"
  description="El pipeline completo de Identidad Artificial: stack técnico, flujo de generación con IA, SEO/GEO, infraestructura Cloudflare y decisiones de diseño. Documentación pública y auditable."
  image="/og/como-funciona.png"
  jsonLd={techArticleSchema}
>
  <!-- Mini hero -->
  <section class="cf-hero">
    <div class="pills-bg" aria-hidden="true">
      {pills.map((row, i) => (
        <div class={`pill-row pill-row-${i % 2 === 0 ? 'left' : 'right'}`}>
          {[...row, ...row, ...row].map(pill => (
            <span class="pill">{pill}</span>
          ))}
        </div>
      ))}
    </div>
    <div class="pills-overlay"></div>
    <div class="cf-hero-content">
      <span class="cf-eyebrow">Transparencia radical</span>
      <h1 class="cf-title">
        Cómo funciona: <span class="accent">stack, pipeline y IA</span>
      </h1>
      <p class="cf-subtitle">
        Stack, pipeline de publicación, IA build-time,<br />SEO/GEO e infraestructura de despliegue.
      </p>
    </div>
  </section>

  <div class="cf-body">

    <!-- Stack -->
    <h2 class="section-label">El stack</h2>
    <div class="stack-grid">
      {stack.map((item, i) => (
        <div class="stack-card fade-up" style={`animation-delay: ${i * 0.04}s`}>
          <span class="stack-icon" aria-hidden="true">{item.icon}</span>
          <div>
            {item.href
              ? <a href={item.href} target="_blank" rel="noopener noreferrer" class="stack-name stack-link">{item.name}</a>
              : <div class="stack-name">{item.name}</div>
            }
            <div class="stack-desc">{item.desc}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Pipeline -->
    <h2 class="section-label">El pipeline de publicación</h2>
    <ol class="pipeline fade-up" style="animation-delay: 0.05s">
      {pipeline.map((step) => (
        <li class="pipeline-step">
          <div class="step-num" aria-hidden="true">{step.n}</div>
          <div class="step-label">{step.label}</div>
        </li>
      ))}
    </ol>

    <!-- Repo structure -->
    <h2 class="section-label">Estructura del repositorio</h2>
    <div class="code-block fade-up" style="animation-delay: 0.05s">
      <pre><code>{`identidad-artificial/
├── source/
│   ├── assets/post/      ← Imágenes hero de los posts
│   ├── content/blog/     ← Posts en .mdx
│   ├── content/tutoriales/ ← Tutoriales IA paso a paso en .mdx
│   ├── components/       ← UI, expediente IA, lecturas y grafo
│   ├── data/generated/   ← Artefactos IA generados en build-time
│   ├── layouts/          ← BaseLayout, PostLayout
│   ├── pages/            ← Rutas del sitio, blog, tutoriales, métricas y legales
│   └── styles/           ← CSS global
├── scripts/
│   ├── content-utils.mjs             ← Lectura segura del corpus MDX
│   ├── generate-og.mjs              ← Imágenes OG
│   ├── generate-knowledge-map.mjs   ← Grafo semántico
│   ├── generate-post-insights.mjs   ← Lecturas por artículo
│   ├── generate-editorial-radar.mjs ← Radar editorial
│   └── google-search-console-*.mjs  ← Informes e inspección GSC
├── docs/
│   ├── guia-crear-post.md     ← Instrucciones para generar posts
│   └── guia-crear-tutorial.md ← Instrucciones para generar tutoriales
├── public/
│   ├── fonts/            ← Inter TTF para satori
│   ├── og/               ← Imágenes OG generadas (no en git)
│   ├── llms.txt          ← Índice breve para motores de IA
│   └── _headers          ← Cabeceras de seguridad para Cloudflare
├── wrangler.toml         ← Configuración del despliegue
└── astro.config.mjs`}</code></pre>
    </div>

    <!-- Frontmatter -->
    <h2 class="section-label">Frontmatter de cada post</h2>
    <p class="cf-note fade-up" style="animation-delay: 0.03s">
      Metadatos de transparencia validados con Zod en build time y mostrados al pie de cada artículo:
    </p>
    <div class="code-block fade-up" style="animation-delay: 0.08s">
      <pre><code>{`---
title: 'Título del post'
description: 'Descripción para SEO'
pubDate: 2026-04-21
category: 'Modelos'
tags: ['llm', 'agentes']
generatedBy: 'claude-sonnet-4-6'
generatedAt: '2026-04-21T10:00:00Z'
promptBase: 'El prompt que se usó para generar este post'
humanReviewed: true
heroImage: '../../assets/post/imagen-del-post.jpg'  # opcional
correctionNote: 'Texto si el post corrige errores de una versión anterior.'  # opcional
sourceQuality: 'Media'        # opcional
confidenceLevel: 'Media'      # opcional
reviewNotes: 'Notas visibles de revisión.'  # opcional
claimsReviewed:
  - 'Afirmación técnica verificada manualmente.'  # opcional
---`}</code></pre>
    </div>
    <p class="cf-note fade-up" style="animation-delay: 0.05s">
      <code>correctionNote</code> aparece como bloque de aviso visible en el post cuando se publica una corrección.
      <code>heroImage</code> referencia una imagen local que Astro optimiza y convierte a AVIF en build time.
      Los campos <code>sourceQuality</code>, <code>confidenceLevel</code>, <code>reviewNotes</code> y
      <code>claimsReviewed</code> alimentan el nuevo expediente IA.
    </p>

    <h2 class="section-label">Frontmatter de cada tutorial</h2>
    <p class="cf-note fade-up" style="animation-delay: 0.03s">
      Los tutoriales viven en una colección separada para tener campos propios: herramienta, dificultad y tiempo estimado.
    </p>
    <div class="code-block fade-up" style="animation-delay: 0.08s">
      <pre><code>{`---
title: 'Título del tutorial'
description: 'Qué aprenderá el lector'
pubDate: 2026-05-18
herramienta: 'ChatGPT'
dificultad: 'Principiante'
tiempoEstimado: '20 minutos'
generatedBy: 'gpt-5'
generatedAt: '2026-05-18T18:00:00Z'
promptBase: 'Resumen del encargo usado para generar el tutorial'
humanReviewed: true
heroImage: '../../assets/post/imagen.jpg'  # opcional
correctionNote: 'Texto si el tutorial corrige una versión anterior.'  # opcional
---`}</code></pre>
    </div>

    <!-- IA build-time -->
    <h2 class="section-label">IA aplicada al sitio</h2>
    <p class="cf-note fade-up" style="animation-delay: 0.03s">
      La IA no aparece como un chatbot en vivo. El enfoque es más barato, auditable y estable:
      el build transforma el corpus en datos derivados que luego se renderizan como páginas estáticas.
    </p>
    <div class="ai-grid">
      {aiSystem.map((item, i) => (
        <div class="ai-card fade-up" style={`animation-delay: ${i * 0.04}s`}>
          <div class="ai-label">{item.label}</div>
          <div class="ai-desc">{item.desc}</div>
        </div>
      ))}
    </div>
    <div class="code-block fade-up" style="animation-delay: 0.08s">
      <pre><code>{`npm run build
└── npm run build:data
    ├── source/data/generated/knowledge-map.ts
    ├── source/data/generated/post-insights.ts
    └── source/data/generated/editorial-radar.ts`}</code></pre>
    </div>

    <!-- Rendimiento web -->
    <h2 class="section-label">Rendimiento web</h2>
    <p class="cf-note fade-up" style="animation-delay: 0.03s">
      El sitio aplica las APIs modernas del navegador para mejorar Core Web Vitals y la experiencia de navegación sin dependencias extra:
    </p>
    <div class="perf-grid">
      {perf.map((item, i) => (
        <div class="perf-card fade-up" style={`animation-delay: ${i * 0.04}s`}>
          <div class="perf-label">{item.label}</div>
          <div class="perf-desc">{item.desc}</div>
        </div>
      ))}
    </div>

    <!-- Accesibilidad -->
    <h2 class="section-label">Accesibilidad</h2>
    <p class="cf-note fade-up" style="animation-delay: 0.03s">
      El sitio cumple WCAG 2.1 AA como mínimo. Las mejoras se aplican progresivamente sin romper la estética ni añadir dependencias externas:
    </p>
    <div class="perf-grid">
      {a11y.map((item, i) => (
        <div class="perf-card fade-up" style={`animation-delay: ${i * 0.04}s`}>
          <div class="perf-label">{item.label}</div>
          <div class="perf-desc">{item.desc}</div>
        </div>
      ))}
    </div>

    <!-- SEO/GEO -->
    <h2 class="section-label">Infraestructura SEO y GEO</h2>
    <p class="cf-note fade-up" style="animation-delay: 0.03s">
      GEO (Generative Engine Optimization) es el equivalente del SEO para motores de respuesta como ChatGPT, Perplexity o Claude. El sitio está preparado para ambos:
    </p>
    <div class="geo-grid">
      {geo.map((item, i) => (
        <div class="geo-card fade-up" style={`animation-delay: ${i * 0.04}s`}>
          <div class="geo-label">{item.label}</div>
          <div class="geo-desc">{item.desc}</div>
        </div>
      ))}
    </div>

    <!-- Seguridad -->
    <h2 class="section-label">Seguridad</h2>
    <p class="cf-note fade-up" style="animation-delay: 0.03s">
      Cabeceras HTTP aplicadas a nivel de Cloudflare via <code>public/_headers</code>:
    </p>
    <div class="security-list fade-up" style="animation-delay: 0.08s">
      {security.map((item) => (
        <div class="security-item">
          <code class="security-label">{item.label}</code>
          <span class="security-desc">{item.desc}</span>
        </div>
      ))}
    </div>

    <!-- Variables de entorno -->
    <h2 class="section-label">Variables de entorno</h2>
    <div class="env-card fade-up" style="animation-delay: 0.05s">
      <span class="env-icon" aria-hidden="true">🔒</span>
      <p>Ninguna credencial está en el repositorio. Las variables de entorno se gestionan exclusivamente en el panel de Cloudflare.</p>
    </div>

    <!-- CTAs -->
    <div class="cf-cta fade-up" style="animation-delay: 0.1s">
      <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="btn-primary">Ver repositorio</a>
      <a href="/" class="btn-secondary">Últimas entradas →</a>
    </div>

  </div>
</BaseLayout>

<style>
/* ── Hero ── */
.cf-hero {
  position: relative;
  overflow: hidden;
  min-height: 240px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pills-bg {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 20px 0;
  pointer-events: none;
  user-select: none;
}

.pill-row {
  display: flex;
  gap: 10px;
  white-space: nowrap;
  width: max-content;
}
.pill-row-left  { animation: scrollLeft  22s linear infinite; }
.pill-row-right { animation: scrollRight 28s linear infinite; }
.pill-row:nth-child(3) { animation-duration: 18s; }

@keyframes scrollLeft  { from { transform: translateX(0); }          to { transform: translateX(-33.333%); } }
@keyframes scrollRight { from { transform: translateX(-33.333%); }   to { transform: translateX(0); } }

.pill {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: 20px;
  border: 1px solid rgba(167, 139, 250, 0.18);
  background: rgba(109, 40, 217, 0.07);
  color: rgba(160, 160, 192, 0.5);
  font-size: 11px;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.pills-overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 60% 80% at 50% 50%,
    rgba(28, 28, 44, 0.95) 0%,
    rgba(28, 28, 44, 0.65) 55%,
    transparent 100%
  );
  pointer-events: none;
}

.cf-hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 44px 24px;
}

.cf-eyebrow {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #A78BFA;
  margin-bottom: 14px;
}

.cf-title {
  font-size: clamp(28px, 5vw, 40px);
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: -1.5px;
  color: #E8E8F0;
  margin-bottom: 12px;
}
.accent { color: #A78BFA; }

.cf-subtitle {
  font-size: 15px;
  color: #A0A0C0;
  line-height: 1.65;
}

/* ── Body ── */
.cf-body {
  max-width: 56rem;
  margin: 0 auto;
  padding: 3rem 1.5rem 4rem;
}

.section-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #A0A0C0;
  padding-bottom: 12px;
  border-bottom: 1px solid #2A2A40;
  margin-bottom: 20px;
  margin-top: 48px;
}
.section-label:first-of-type { margin-top: 0; }

.cf-note {
  font-size: 14px;
  color: #C8C8E0;
  line-height: 1.7;
  margin-bottom: 16px;
}
.cf-note code {
  font-family: monospace;
  font-size: 12px;
  color: #E8E8F0;
  background: #24243A;
  padding: 2px 6px;
  border-radius: 4px;
}

/* ── Stack ── */
.stack-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: #2A2A40;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  overflow: hidden;
}

.stack-card {
