---
import LabLayout from '../../layouts/LabLayout.astro'
import { LAB_DEMOS, webAppSchema } from '../../lib/lab/schema'
import { PRICED_MODELS } from '../../data/model-pricing'

const demo = LAB_DEMOS.find(d => d.slug === 'calculadora-contexto')!
const updated = PRICED_MODELS[0].updated
---

<LabLayout
  title="Calculadora de contexto y costes LLM"
  description="Compara cuánto cuesta tu texto en 10 LLMs actuales (Claude, GPT, Gemini, DeepSeek, Llama) y qué porcentaje de la ventana de contexto ocupa. Sin enviar datos."
  image="/og/laboratorio-calculadora.png"
  jsonLd={webAppSchema(demo)}
  heading="Contexto y costes"
  subtitle="Pega un texto (o escribe un número de tokens directamente) y compara qué costaría procesarlo en los principales modelos y cuánta ventana de contexto consume. Los precios son por millón de tokens, según tarifas públicas."
>
  <div class="ctx-app">
    <div class="ctx-inputs">
      <div class="ctx-input-block">
        <label class="ctx-label" for="ctx-text">Texto de entrada</label>
        <textarea id="ctx-text" class="ctx-textarea" rows="5" placeholder="Pega aquí tu prompt, documento o conversación…" spellcheck="false"></textarea>
        <label class="ctx-precise">
          <input type="checkbox" id="ctx-precise-toggle" />
          Recuento preciso con tokenizador real (descarga ~800 KB)
        </label>
      </div>
      <div class="ctx-numbers">
        <div class="ctx-number">
          <label class="ctx-label" for="ctx-input-tokens">Tokens de entrada</label>
          <input type="number" id="ctx-input-tokens" min="0" step="100" value="0" />
        </div>
        <div class="ctx-number">
          <label class="ctx-label" for="ctx-output-tokens">Tokens de salida</label>
          <input type="number" id="ctx-output-tokens" min="0" step="100" value="1000" />
        </div>
        <p class="ctx-method" id="ctx-method">Estimación: caracteres ÷ 4</p>
      </div>
    </div>

    <div class="ctx-table-wrap">
      <table class="ctx-table">
        <thead>
          <tr>
            <th>Modelo</th>
            <th>Contexto</th>
            <th>Entrada</th>
            <th>Salida</th>
            <th>Total</th>
            <th class="ctx-th-window">% ventana</th>
          </tr>
        </thead>
        <tbody id="ctx-tbody"></tbody>
      </table>
    </div>
    <p class="ctx-updated">Precios actualizados: {updated} · USD por millón de tokens · la estimación chars/4 es orientativa: cada modelo tokeniza distinto.</p>

    <div class="ctx-explainer">
      <h2>Para entender la tabla</h2>
      <p>
        La <strong>ventana de contexto</strong> es la memoria de trabajo del modelo: todo lo que entra
        (instrucciones, documentos, conversación) compite por ese espacio. Si tu texto ocupa el 80% de
        la ventana, apenas queda sitio para la respuesta. Explicación completa en
        <a href="/como-funciona-el-contexto-en-los-llm/">cómo funciona el contexto en los LLM</a>.
      </p>
    </div>
  </div>
</LabLayout>

<script>
  import { PRICED_MODELS, COMPANY_COLORS } from '../../data/model-pricing'
  import { estimateTokensFromText, computeCostTable, formatUSD } from '../../lib/lab/cost'

  const textInput = document.getElementById('ctx-text') as HTMLTextAreaElement
  const preciseToggle = document.getElementById('ctx-precise-toggle') as HTMLInputElement
  const inputTokens = document.getElementById('ctx-input-tokens') as HTMLInputElement
  const outputTokens = document.getElementById('ctx-output-tokens') as HTMLInputElement
  const method = document.getElementById('ctx-method') as HTMLParagraphElement
  const tbody = document.getElementById('ctx-tbody') as HTMLTableSectionElement

  let encode: ((text: string) => number[]) | null = null

  async function tokensFromText(text: string): Promise<number> {
    if (preciseToggle.checked) {
      if (!encode) {
        method.textContent = 'Cargando tokenizador…'
        try {
          const mod = await import('gpt-tokenizer/encoding/o200k_base')
          encode = mod.encode
        } catch {
          method.textContent = 'Error cargando el tokenizador — usando estimación chars/4'
          preciseToggle.checked = false
          return estimateTokensFromText(text)
        }
      }
      method.textContent = 'Recuento real con o200k_base'
      return text.length === 0 ? 0 : encode(text).length
    }
    method.textContent = 'Estimación: caracteres ÷ 4'
    return estimateTokensFromText(text)
  }

  function fmtTokens(n: number): string {
    return n.toLocaleString('es-ES')
  }

  function fmtWindow(n: number): string {
    if (n >= 1_000_000) return `${n / 1_000_000}M`
    return `${Math.round(n / 1000)}K`
  }

  function render() {
    const inTok = Math.max(0, parseInt(inputTokens.value, 10) || 0)
    const outTok = Math.max(0, parseInt(outputTokens.value, 10) || 0)
    const rows = computeCostTable(PRICED_MODELS, inTok, outTok)

    tbody.replaceChildren(...rows.map(row => {
      const tr = document.createElement('tr')
      const color = COMPANY_COLORS[row.model.company] ?? '#A78BFA'
      const pct = Math.min(100, row.contextPct)
      tr.innerHTML = `
        <td><span class="ctx-dot" style="background:${color}"></span>${row.model.name}</td>
        <td class="num">${fmtWindow(row.model.contextWindow)}</td>
        <td class="num">${formatUSD(row.inputCost)}</td>
        <td class="num">${formatUSD(row.outputCost)}</td>
        <td class="num total">${formatUSD(row.totalCost)}</td>
        <td class="bar-cell">
          <div class="ctx-bar-track${row.fitsInContext ? '' : ' overflow'}">
            <div class="ctx-bar-fill" style="width:${pct.toFixed(2)}%;background:${row.fitsInContext ? color : '#F87171'}"></div>
          </div>
          <span class="ctx-pct${row.fitsInContext ? '' : ' overflow'}">${row.fitsInContext ? `${row.contextPct < 0.01 && inTok > 0 ? '<0.01' : row.contextPct.toFixed(row.contextPct < 1 ? 2 : 1)}%` : 'no cabe'}</span>
        </td>`
      return tr
    }))
  }

  let debounce: ReturnType<typeof setTimeout> | undefined
  textInput.addEventListener('input', () => {
    clearTimeout(debounce)
    debounce = setTimeout(async () => {
      inputTokens.value = String(await tokensFromText(textInput.value))
      render()
    }, 150)
  })

  preciseToggle.addEventListener('change', async () => {
    if (textInput.value.length > 0) {
      inputTokens.value = String(await tokensFromText(textInput.value))
    } else {
      await tokensFromText('')
    }
    render()
  })

  inputTokens.addEventListener('input', render)
  outputTokens.addEventListener('input', render)

  render()
</script>

<style>
.ctx-app { max-width: 860px; }

.ctx-inputs {
  display: grid;
  grid-template-columns: 1fr 220px;
  gap: 20px;
  margin-bottom: 24px;
}
@media (max-width: 640px) {
  .ctx-inputs { grid-template-columns: 1fr; }
}

.ctx-label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #A0A0C0;
  margin-bottom: 8px;
}

.ctx-textarea {
  width: 100%;
  background: #13131F;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  color: #E8E8F0;
  font-size: 14px;
  line-height: 1.6;
  padding: 12px 14px;
  resize: vertical;
}
.ctx-textarea:focus { outline: none; border-color: #A78BFA; }

.ctx-precise {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: #A0A0C0;
  margin-top: 8px;
  cursor: pointer;
}
.ctx-precise input { accent-color: #A78BFA; }

.ctx-numbers { display: flex; flex-direction: column; gap: 14px; }
.ctx-number input {
  width: 100%;
  background: #13131F;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  color: #E8E8F0;
  font-size: 16px;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  padding: 10px 12px;
}
.ctx-number input:focus { outline: none; border-color: #A78BFA; }
.ctx-method { font-size: 11px; color: #9A9ABF; }

.ctx-table-wrap { overflow-x: auto; }
.ctx-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  background: #13131F;
  border: 1px solid #2A2A40;
  border-radius: 8px;
}
.ctx-table th {
  text-align: left;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #A0A0C0;
  padding: 10px 12px;
  border-bottom: 1px solid #2A2A40;
}
.ctx-table th.ctx-th-window { min-width: 140px; }
.ctx-table :global(td) {
  padding: 9px 12px;
  border-bottom: 1px solid #1F1F33;
  color: #E8E8F0;
  white-space: nowrap;
}
.ctx-table :global(tr:last-child td) { border-bottom: none; }
.ctx-table :global(td.num) { font-variant-numeric: tabular-nums; color: #A0A0C0; }
.ctx-table :global(td.total) { color: #E8E8F0; font-weight: 700; }
.ctx-table :global(.ctx-dot) {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-right: 8px;
}
.ctx-table :global(.bar-cell) { min-width: 140px; }
.ctx-table :global(.ctx-bar-track) {
  display: inline-block;
  vertical-align: middle;
  width: 80px;
  height: 6px;
  background: #1F1F33;
  border-radius: 3px;
  overflow: hidden;
  margin-right: 8px;
}
.ctx-table :global(.ctx-bar-fill) { height: 100%; border-radius: 3px; transition: width 0.25s ease; }
.ctx-table :global(.ctx-pct) { font-size: 11px; color: #A0A0C0; font-variant-numeric: tabular-nums; }
.ctx-table :global(.ctx-pct.overflow) { color: #F87171; font-weight: 700; }

.ctx-updated { font-size: 11px; color: #9A9ABF; margin-top: 10px; }

.ctx-explainer { margin-top: 32px; max-width: 680px; }
.ctx-explainer h2 {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #A78BFA;
  margin-bottom: 10px;
}
.ctx-explainer p { font-size: 14px; line-height: 1.7; color: #A0A0C0; }
.ctx-explainer a { color: #A78BFA; }
</style>
