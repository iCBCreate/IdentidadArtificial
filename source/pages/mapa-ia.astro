---
import BaseLayout from '../layouts/BaseLayout.astro'
import KnowledgeGraph from '../components/KnowledgeGraph.astro'
import { KNOWLEDGE_MAP } from '../data/generated/knowledge-map'
---

<BaseLayout
  title="Mapa IA"
  description="Grafo semántico generado en build-time a partir de artículos, tags, conceptos y relaciones de Identidad Artificial."
>
  <section class="page-hero">
    <p>Base de conocimiento</p>
    <h1>Mapa semántico de IA</h1>
    <span>
      Artículos, conceptos, empresas y categorías conectados por el pipeline del sitio.
      No usa IA en vivo: los datos se derivan durante el build.
    </span>
  </section>

  <div class="page-body">
    <KnowledgeGraph nodes={KNOWLEDGE_MAP.nodes} links={KNOWLEDGE_MAP.links} />
  </div>
</BaseLayout>

<style>
.page-hero {
  max-width: 64rem;
  margin: 0 auto;
  padding: 56px 24px 26px;
}
.page-hero p {
  color: #60A5FA;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
}
h1 {
  color: #E8E8F0;
  font-size: clamp(34px, 6vw, 58px);
  font-weight: 900;
  line-height: 1;
  margin-top: 10px;
}
.page-hero span {
  display: block;
  max-width: 680px;
  color: #A0A0C0;
  font-size: 16px;
  line-height: 1.7;
  margin-top: 16px;
}
.page-body {
  max-width: 72rem;
  margin: 0 auto;
  padding: 16px 24px 48px;
}
</style>
