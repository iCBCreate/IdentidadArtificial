---
import BaseLayout from '../layouts/BaseLayout.astro'
import EditorialRadar from '../components/EditorialRadar.astro'
import { EDITORIAL_RADAR } from '../data/generated/editorial-radar'
---

<BaseLayout
  title="Radar Editorial IA"
  description="Temas detectados por el radar editorial de Identidad Artificial a partir del corpus existente."
>
  <section class="page-hero">
    <p>Sistema editorial</p>
    <h1>Radar Editorial IA</h1>
    <span>
      Temas que el pipeline sugiere vigilar a partir del contenido publicado,
      las etiquetas existentes y los huecos técnicos del proyecto.
    </span>
  </section>

  <div class="page-body">
    <EditorialRadar radar={EDITORIAL_RADAR} />
  </div>
</BaseLayout>

<style>
.page-hero {
  max-width: 64rem;
  margin: 0 auto;
  padding: 56px 24px 26px;
}
.page-hero p {
  color: #34D399;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
}
h1 {
  color: #E8E8F0;
  font-size: clamp(34px, 6vw, 58px);
  font-weight: 900;
  line-height: 1;
  margin-top: 10px;
}
.page-hero span {
  display: block;
  max-width: 680px;
  color: #A0A0C0;
  font-size: 16px;
  line-height: 1.7;
  margin-top: 16px;
}
.page-body {
  max-width: 64rem;
  margin: 0 auto;
  padding: 16px 24px 48px;
}
</style>
