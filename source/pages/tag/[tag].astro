---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PostCard from '../../components/PostCard.astro'
import { SITE } from '../../config'
import { getSortedPosts, calcReadingTime } from '../../lib/posts'

export async function getStaticPaths() {
  const allPosts = await getSortedPosts()

  const tagMap = new Map<string, typeof allPosts>()
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      const existing = tagMap.get(tag) ?? []
      existing.push(post)
      tagMap.set(tag, existing)
    }
  }

  // Only generate pages for tags with 2+ posts to avoid thin content
  return [...tagMap.entries()]
    .filter(([, posts]) => posts.length >= 2)
    .map(([tag, posts]) => ({
      params: { tag },
      props: { tag, posts },
    }))
}

interface Props {
  tag: string
  posts: Awaited<ReturnType<typeof getSortedPosts>>
}

const { tag, posts } = Astro.props
const canonicalURL = new URL(`/tag/${tag}/`, SITE.url).href
const displayTag = tag.replace(/-/g, ' ')

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${displayTag} — ${SITE.name}`,
  description: `Artículos etiquetados con "${displayTag}" en Identidad Artificial.`,
  url: canonicalURL,
  inLanguage: 'es',
  isAccessibleForFree: true,
  author: {
    '@type': 'Person',
    name: SITE.author,
    url: `${SITE.url}/sobre/`,
  },
  mainEntity: {
    '@type': 'ItemList',
    name: `Artículos sobre ${displayTag}`,
    numberOfItems: posts.length,
    itemListElement: posts.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: post.data.title,
      url: `${SITE.url}/${post.id}/`,
    })),
  },
}
---

<BaseLayout
  title={`${displayTag} — IA en español`}
  description={`Artículos etiquetados con "${displayTag}" en Identidad Artificial. Análisis técnicos sobre IA en español.`}
  jsonLd={jsonLd}
>
  <section class="tag-hero">
    <span class="tag-eyebrow">Etiqueta</span>
    <h1 class="tag-title">#{displayTag}</h1>
    <p class="tag-count">
      <span class="count-num">{posts.length}</span>
      {posts.length === 1 ? ' artículo' : ' artículos'}
    </p>
  </section>

  <div class="tag-body">
    <nav class="tag-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span>›</span>
      <a href="/archivo/">Artículos</a>
      <span>›</span>
      <span>#{displayTag}</span>
    </nav>

    <div class="cards-grid">
      {posts.map((post, i) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          slug={post.id}
          heroImage={post.data.heroImage}
          readingTime={calcReadingTime(post.body ?? '')}
          featured={false}
          priority={i === 0}
        />
      ))}
    </div>

    <p class="back-link"><a href="/archivo/">← Todos los artículos</a></p>
  </div>
</BaseLayout>

<style>
.tag-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px 40px;
  text-align: center;
  background: linear-gradient(135deg, #0d0d1a 0%, #1a1035 100%);
  border-bottom: 1px solid #2A2A40;
}

.tag-eyebrow {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #6A6A8A;
  margin-bottom: 10px;
}

.tag-title {
  font-size: clamp(28px, 5vw, 42px);
  font-weight: 800;
  letter-spacing: -1.5px;
  color: #A78BFA;
  line-height: 1;
  margin-bottom: 10px;
}

.tag-count {
  font-size: 13px;
  color: #6A6A8A;
}
.count-num {
  font-weight: 700;
  color: #A78BFA;
}

.tag-body {
  max-width: 64rem;
  margin: 0 auto;
  padding: 2rem 1.5rem 4rem;
}

.tag-breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: #6A6A8A;
  margin-bottom: 24px;
}
.tag-breadcrumb a {
  color: #A78BFA;
  text-decoration: none;
  transition: color 0.15s;
}
.tag-breadcrumb a:hover { color: #E8E8F0; }

.cards-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1px;
  background: #2A2A40;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 32px;
}

@media (max-width: 768px) {
  .cards-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .cards-grid { grid-template-columns: 1fr; }
}

.back-link a {
  font-size: 13px;
  color: #A78BFA;
  text-decoration: none;
  transition: color 0.15s;
}
.back-link a:hover { color: #E8E8F0; }
</style>
