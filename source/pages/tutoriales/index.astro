---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { SITE } from '../../config'

const tutoriales = await getCollection('tutoriales')
const sorted = tutoriales.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Tutoriales de IA para Principiantes',
  description: 'Guías paso a paso para aprender a usar herramientas de IA generativa',
  url: `${SITE.url}/tutoriales/`,
  numberOfItems: sorted.length,
  itemListElement: sorted.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: t.data.title,
    url: `${SITE.url}/tutoriales/${t.id}/`,
  })),
}
---

<BaseLayout
  title="Tutoriales de IA para Principiantes — ChatGPT, Claude y Gemini"
  description="Guías paso a paso para principiantes: aprende a usar ChatGPT, Claude, Gemini y otras herramientas de IA desde cero. Empieza sin conocimientos previos."
  image="/og/tutoriales.png"
  jsonLd={itemListSchema}
>
  <section class="tutoriales-hero">
    <div class="tutoriales-hero-content">
      <p class="tutoriales-eyebrow">Aprende IA</p>
      <h1>Tutoriales de IA para Principiantes</h1>
      <span class="tutoriales-subtitle">Guías prácticas para empezar con herramientas de IA</span>
    </div>
  </section>

  <div class="tutoriales-body">
    <div class="tutoriales-intro">
      <p>
        Cada tutorial es una guía autosuficiente: explica qué hacer y por qué, paso a paso,
        sin asumir conocimientos previos. El foco está en herramientas reales —
        <strong>ChatGPT</strong>, <strong>Claude</strong> y <strong>Gemini</strong> —
        con ejemplos prácticos y resultados esperados. El tiempo estimado es realista.
        Si quieres entender cómo se generan y revisan estos tutoriales,
        <a href="/como-funciona/">consulta cómo funciona el sitio</a>.
      </p>
    </div>

    <div class="tutoriales-grid">
      {sorted.map(tutorial => (
        <a href={`/tutoriales/${tutorial.id}/`} class="tutorial-card">
          <div class="card-header">
            <h2>{tutorial.data.title}</h2>
            <div class="card-badges">
              <span class="tool-badge">{tutorial.data.herramienta}</span>
              <span class={`difficulty-badge difficulty-${tutorial.data.dificultad.toLowerCase()}`}>
                {tutorial.data.dificultad}
              </span>
            </div>
          </div>
          <p class="card-description">{tutorial.data.description}</p>
          <div class="card-footer">
            <span class="time-badge">⏱ {tutorial.data.tiempoEstimado}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
.tutoriales-hero {
  max-width: 64rem;
  margin: 0 auto;
  padding: 56px 24px 26px;
}

.tutoriales-hero-content {
  text-align: center;
}

.tutoriales-eyebrow {
  display: inline-block;
  color: #60A5FA;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
  margin-bottom: 10px;
}

h1 {
  color: #E8E8F0;
  font-size: clamp(28px, 5vw, 48px);
  font-weight: 900;
  line-height: 1.1;
  margin-top: 10px;
}

.tutoriales-subtitle {
  display: block;
  max-width: 680px;
  margin: 0 auto;
  color: #A0A0C0;
  font-size: 16px;
  line-height: 1.7;
  margin-top: 16px;
}

.tutoriales-body {
  max-width: 72rem;
  margin: 0 auto;
  padding: 16px 24px 48px;
}

.tutoriales-intro {
  max-width: 680px;
  margin: 0 auto 32px;
  text-align: center;
}

.tutoriales-intro p {
  color: #A0A0C0;
  font-size: 15px;
  line-height: 1.7;
  margin: 0;
}

.tutoriales-intro strong {
  color: #C8C8E0;
}

.tutoriales-intro a {
  color: #60A5FA;
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: border-color 0.15s;
}
.tutoriales-intro a:hover {
  border-bottom-color: #60A5FA;
}

.tutoriales-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
}

.tutorial-card {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px;
  border: 1px solid #2A2A40;
  border-radius: 8px;
  background: #1C1C2E;
  transition: all 0.2s;
  text-decoration: none;
  color: inherit;
}

.tutorial-card:hover {
  border-color: #A78BFA;
  background: #262638;
  transform: translateY(-2px);
}

.card-header {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.card-header h2 {
  color: #E8E8F0;
  font-size: 16px;
  font-weight: 600;
  line-height: 1.4;
  margin: 0;
}

.card-badges {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.tool-badge {
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 4px;
  background: rgba(96, 165, 250, 0.1);
  color: #60A5FA;
  border: 1px solid rgba(96, 165, 250, 0.2);
}

.difficulty-badge {
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 4px;
  border: 1px solid;
}

.difficulty-principiante {
  background: rgba(34, 197, 94, 0.1);
  color: #22C55E;
  border-color: rgba(34, 197, 94, 0.2);
}

.difficulty-intermedio {
  background: rgba(251, 146, 60, 0.1);
  color: #FB923C;
  border-color: rgba(251, 146, 60, 0.2);
}

.card-description {
  color: #A0A0C0;
  font-size: 14px;
  line-height: 1.5;
  margin: 0;
  flex-grow: 1;
}

.card-footer {
  display: flex;
  justify-content: flex-start;
  padding-top: 8px;
  border-top: 1px solid #2A2A40;
}

.time-badge {
  font-size: 12px;
  color: #6A6A8A;
  font-weight: 500;
}
</style>
